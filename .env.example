# Copy to .env and fill in. .env is gitignored.

# Public hostname used by absolute URLs in outbound mailer templates
# (invitations, password resets). Read only by production.rb; defaults
# to "localhost" if unset, so dev/test work without it. Set this on
# Heroku to your public domain (e.g. app.example.com) — the in-app
# missing-env banner flags it as missing in non-development envs.
APP_HOST=

# Active Storage — pick ONE provider for production.
#
# Google Cloud Storage (preferred). Used by config/storage.yml :google when
# GCS_BUCKET is set. Locally, you can omit GCS_CREDENTIALS and run
# `gcloud auth application-default login` to use ADC; on Heroku, paste the
# entire service-account keyfile JSON into GCS_CREDENTIALS.
GCS_PROJECT=
GCS_BUCKET=
GCS_CREDENTIALS=

# Amazon S3 (fallback). Used by config/storage.yml :amazon when AWS_BUCKET
# is set AND GCS_BUCKET is not.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET=

# RubyLLM provider key (read by config/initializers/ruby_llm.rb)
GEMINI_API_KEY=

# Google OAuth (read by config/initializers/omniauth.rb for Gmail send-on-behalf-of)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Error reporting (read by config/initializers/sentry.rb)
SENTRY_DSN=

# Outbound mail safety gate (read by app/jobs/campaign_sweep_job.rb).
# Required in development — without it the campaign sweep is a no-op and
# nothing sends. When set in any environment, all campaign mail is
# redirected here instead of going to the real customer address.
# Devise mailers (password reset, etc.) are unaffected.
TEST_TO_EMAIL=
