# Copy to .env and fill in. .env is gitignored.

# Active Storage / S3 (used by config/storage.yml :amazon service in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET=

# RubyLLM provider key (read by config/initializers/ruby_llm.rb)
GEMINI_API_KEY=

# Google OAuth (read by config/initializers/omniauth.rb for Gmail send-on-behalf-of)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Error reporting (read by config/initializers/bugsnag.rb)
BUGSNAG_API_KEY=
