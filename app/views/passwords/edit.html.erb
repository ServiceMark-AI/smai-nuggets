<% content_for :title, "Change Password" %>

<div class="row justify-content-center">
  <div class="col-md-8 col-lg-6">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h2 class="card-title mb-4">Change Password</h2>

        <%= form_with model: @user, url: change_password_path, method: :patch, local: true do |f| %>
          <% if @user.errors.any? %>
            <div class="alert alert-danger">
              <h6 class="alert-heading mb-2"><%= pluralize(@user.errors.count, "error") %> prevented your password from being changed:</h6>
              <ul class="mb-0">
                <% @user.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="mb-3">
            <%= f.label :current_password, class: "form-label" %>
            <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control", autofocus: true %>
          </div>

          <div class="mb-3">
            <%= f.label :password, "New password", class: "form-label" %>
            <% if @minimum_password_length || (devise_mapping = Devise.mappings[:user]).validatable? %>
              <small class="form-text text-muted d-block mb-1">(<%= User.password_length.min %> characters minimum)</small>
            <% end %>
            <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.label :password_confirmation, "Confirm new password", class: "form-label" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
          </div>

          <div class="d-flex gap-2">
            <%= f.submit "Update password", class: "btn btn-primary" %>
            <%= link_to "Cancel", profile_path, class: "btn btn-outline-secondary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
