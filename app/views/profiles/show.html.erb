<% content_for :title, "Profile" %>

<div class="row justify-content-center">
  <div class="col-md-8 col-lg-6">
    <div class="card shadow-sm mb-4">
      <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h2 class="card-title mb-0">Your Profile</h2>
          <%= link_to "Edit", edit_profile_path, class: "btn btn-sm btn-outline-primary" %>
        </div>

        <dl class="row mb-0">
          <dt class="col-sm-4">Email</dt>
          <dd class="col-sm-8"><%= @user.email %></dd>

          <dt class="col-sm-4">First name</dt>
          <dd class="col-sm-8"><%= @user.first_name.presence || content_tag(:span, "—", class: "text-muted") %></dd>

          <dt class="col-sm-4">Last name</dt>
          <dd class="col-sm-8"><%= @user.last_name.presence || content_tag(:span, "—", class: "text-muted") %></dd>

          <dt class="col-sm-4">Phone number</dt>
          <dd class="col-sm-8"><%= @user.phone_number.presence || content_tag(:span, "—", class: "text-muted") %></dd>

          <dt class="col-sm-4">Tenant</dt>
          <dd class="col-sm-8"><%= @user.tenant&.name || content_tag(:span, "—", class: "text-muted") %></dd>

          <dt class="col-sm-4">Last login</dt>
          <dd class="col-sm-8"><%= @user.last_sign_in_at&.to_fs(:long) || content_tag(:span, "—", class: "text-muted") %></dd>

          <dt class="col-sm-4">Sign-in count</dt>
          <dd class="col-sm-8"><%= @user.sign_in_count %></dd>

          <dt class="col-sm-4">Status</dt>
          <dd class="col-sm-8">
            <% if @user.is_pending %>
              <span class="badge text-bg-warning">Pending</span>
            <% else %>
              <span class="badge text-bg-success">Active</span>
            <% end %>
          </dd>
        </dl>
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h2 class="card-title mb-0 h5">Email sending</h2>
          <%= button_to "Setup G Suite", "/auth/google_oauth2", method: :post, class: "btn btn-sm btn-outline-primary", form: { class: "m-0" } %>
        </div>

        <% delegations = @user.email_delegations.order(:email) %>
        <% if delegations.any? %>
          <ul class="list-group list-group-flush">
            <% delegations.each do |d| %>
              <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                <div>
                  <div class="fw-semibold"><%= d.email %></div>
                  <div class="small text-muted">
                    <%= d.provider.humanize %>
                    <% if d.expires_at %>
                      · token <%= d.expired? ? "expired" : "expires" %> <%= time_ago_in_words(d.expires_at, include_seconds: false) %><%= d.expired? ? " ago" : "" %>
                    <% end %>
                  </div>
                </div>
                <%= button_to "Disconnect", email_delegation_path(d), method: :delete, class: "btn btn-sm btn-outline-danger", form: { class: "m-0", data: { turbo_confirm: "Disconnect #{d.email}?" } } %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted mb-0">No connected accounts. Click Setup G Suite to authorize.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
