<% content_for :title, "Edit Profile" %>

<div class="row justify-content-center">
  <div class="col-md-8 col-lg-6">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h2 class="card-title mb-4">Edit Profile</h2>

        <%= form_with model: @user, url: profile_path, method: :patch, local: true do |f| %>
          <% if @user.errors.any? %>
            <div class="alert alert-danger">
              <h6 class="alert-heading mb-2"><%= pluralize(@user.errors.count, "error") %> prevented your profile from being saved:</h6>
              <ul class="mb-0">
                <% @user.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="row g-3 mb-3">
            <div class="col-sm-6">
              <%= f.label :first_name, class: "form-label" %>
              <%= f.text_field :first_name, class: "form-control", autofocus: true %>
            </div>
            <div class="col-sm-6">
              <%= f.label :last_name, class: "form-label" %>
              <%= f.text_field :last_name, class: "form-control" %>
            </div>
          </div>

          <div class="mb-3">
            <%= f.label :title, class: "form-label" %>
            <%= f.text_field :title, class: "form-control", placeholder: "e.g. Estimator" %>
            <div class="form-text">Shown in your email signature.</div>
          </div>

          <div class="mb-3">
            <%= f.label :phone_number, class: "form-label" %>
            <%= f.telephone_field :phone_number, class: "form-control" %>
          </div>

          <div class="d-flex gap-2">
            <%= f.submit "Save", class: "btn btn-primary" %>
            <%= link_to "Cancel", profile_path, class: "btn btn-outline-secondary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
