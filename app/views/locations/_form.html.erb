<%= form_with model: @location, url: location_form_url, method: location_form_method, local: true do |f| %>
  <% if @location.errors.any? %>
    <div class="alert alert-danger">
      <strong>Please fix the following:</strong>
      <ul class="mb-0">
        <% @location.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :display_name, class: "form-label" %>
    <%= f.text_field :display_name, class: "form-control", required: true, autofocus: true,
          placeholder: "e.g., NE Dallas" %>
    <div class="form-text">Used in email signatures and the operator UI.</div>
  </div>

  <div class="mb-3">
    <%= f.label :address_line_1, "Address line 1", class: "form-label" %>
    <%= f.text_field :address_line_1, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :address_line_2, "Address line 2 (optional)", class: "form-label" %>
    <%= f.text_field :address_line_2, class: "form-control" %>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :city, class: "form-label" %>
      <%= f.text_field :city, class: "form-control", required: true %>
    </div>
    <div class="col-md-3 mb-3">
      <%= f.label :state, class: "form-label" %>
      <%= f.text_field :state, class: "form-control", required: true,
            maxlength: 2, minlength: 2, pattern: "[A-Za-z]{2}",
            placeholder: "TX" %>
      <div class="form-text">Two-letter US state code.</div>
    </div>
    <div class="col-md-3 mb-3">
      <%= f.label :postal_code, "Postal code", class: "form-label" %>
      <%= f.text_field :postal_code, class: "form-control", required: true %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :phone_number, class: "form-label" %>
    <%= f.text_field :phone_number, class: "form-control", required: true,
          placeholder: "(214) 555-0100" %>
    <div class="form-text">Office phone, used in email signatures.</div>
  </div>

  <div class="mb-3 form-check">
    <%= f.check_box :is_active, class: "form-check-input" %>
    <%= f.label :is_active, "Active", class: "form-check-label" %>
    <div class="form-text">Activated locations are visible to the operator product. Required fields must all be present.</div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit submit_label, class: "btn btn-primary" %>
    <%= link_to "Cancel", cancel_url, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
