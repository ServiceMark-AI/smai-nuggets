<% content_for :title, "Add Location" %>

<%= render "shared/breadcrumb", at: :location_new %>

<h1 class="h3 mb-4">Add Location</h1>

<p class="text-muted">
  One location per organization. Required fields below feed the email signature
  block. The location stays inactive until every required field is present.
</p>

<%= render "form",
      location_form_url: location_path,
      location_form_method: :post,
      submit_label: "Add Location",
      cancel_url: my_organization_path %>
