<%
  organization = current_user&.organizations&.first
  location = organization&.location
  tenant = organization&.tenant || current_user&.tenant

  tenant_label = tenant&.name || "Tenant"
  org_label = organization&.name || "Organization"
  location_label = location&.display_name.presence || "Location"

  segments = []
  segments << { label: tenant_label, href: nil, active: at == :tenant }
  segments << {
    label: org_label,
    href: organization ? my_organization_path : nil,
    active: at == :my_organization
  }
  segments << {
    label: location_label,
    href: organization ? (location ? edit_location_path : new_location_path) : nil,
    active: at == :location_edit || at == :location_new
  }
%>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb mb-0">
    <% segments.each_with_index do |seg, i| %>
      <% is_last = i == segments.size - 1 %>
      <li class="breadcrumb-item <%= 'active' if seg[:active] %>"
          <%= 'aria-current="page"'.html_safe if seg[:active] %>>
        <% if seg[:active] || seg[:href].nil? %>
          <%= seg[:label] %>
        <% else %>
          <%= link_to seg[:label], seg[:href] %>
        <% end %>
      </li>
    <% end %>
  </ol>
</nav>
