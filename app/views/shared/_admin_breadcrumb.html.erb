<%
  # Admin-side breadcrumb. Pass the records explicitly:
  #   render "shared/admin_breadcrumb", tenant: @tenant, location: @location, current: :location
  # current ∈ { :tenant, :location }. Segments without a record are skipped.

  segments = []
  if tenant
    segments << {
      label: tenant.name,
      href: current == :tenant ? nil : admin_tenant_path(tenant),
      active: current == :tenant
    }
  end
  if local_assigns[:location]
    segments << {
      label: location.display_name.presence || "Location",
      href: nil,
      active: current == :location
    }
  end
%>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb mb-0">
    <% segments.each do |seg| %>
      <li class="breadcrumb-item <%= 'active' if seg[:active] %>"
          <%= 'aria-current="page"'.html_safe if seg[:active] %>>
        <% if seg[:href] %>
          <%= link_to seg[:label], seg[:href] %>
        <% else %>
          <%= seg[:label] %>
        <% end %>
      </li>
    <% end %>
  </ol>
</nav>
