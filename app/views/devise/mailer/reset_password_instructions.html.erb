<%
  reset_url = edit_password_url(@resource, reset_password_token: @token)

  intro = capture do %>
    <p style="margin: 0 0 16px 0; font-size: 15px; line-height: 1.6; color: #424a53;">
      Hi <strong><%= @resource.display_name.presence || @resource.email %></strong>,
    </p>
    <p style="margin: 0 0 16px 0; font-size: 15px; line-height: 1.6; color: #424a53;">
      Someone — hopefully you — requested a password reset for your ServiceMark AI account.
    </p>
    <p style="margin: 0 0 28px 0; font-size: 15px; line-height: 1.6; color: #424a53;">
      Click the button below to choose a new password. Your existing password stays active until you finish that step.
    </p>
  <% end

  footer = capture do %>
    <p style="margin: 0; font-size: 13px; color: #6c757d; line-height: 1.5;">
      If you didn't request this, you can safely ignore this email — nothing changes until the link above is used.
    </p>
  <% end %>

<%= render "shared/email_shell",
      title:     "Reset your ServiceMark AI password",
      heading:   "Reset your password",
      intro:     intro,
      cta_label: "Reset password",
      cta_url:   reset_url,
      footer:    footer %>
