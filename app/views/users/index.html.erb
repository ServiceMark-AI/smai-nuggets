<% content_for :title, "Users" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0">Users</h1>
  <% if @tenant %>
    <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#inviteUserModal">
      Invite user
    </button>
  <% end %>
</div>

<% if @tenant.nil? %>
  <div class="alert alert-info mb-0">
    You're not assigned to a tenant yet. An admin needs to add you to one before you can invite teammates.
  </div>
<% else %>
  <div class="card shadow-sm mb-4">
    <div class="card-header">
      <h2 class="h5 mb-0"><%= @tenant.name %> · <%= pluralize(@users.size, "member") %></h2>
    </div>
    <div class="card-body p-0">
      <% if @users.any? %>
        <table class="table table-hover mb-0 align-middle">
          <thead class="table-light">
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Organizations</th>
              <th>Gmail</th>
              <th class="text-end">Status</th>
            </tr>
          </thead>
          <tbody>
            <% @users.each do |user| %>
              <tr>
                <td>
                  <% if user.full_name.present? %>
                    <%= user.full_name %>
                  <% else %>
                    <span class="text-muted">—</span>
                  <% end %>
                </td>
                <td><%= user.email %></td>
                <td>
                  <% org_names = user.organizations.where(tenant_id: @tenant.id).pluck(:name) %>
                  <% if org_names.any? %>
                    <%= org_names.join(", ") %>
                  <% else %>
                    <span class="text-muted">—</span>
                  <% end %>
                </td>
                <td>
                  <% gmail_delegation = user.email_delegations.find { |d| d.provider == "google" } %>
                  <% if gmail_delegation %>
                    <span class="badge text-bg-success">Linked</span>
                    <div class="text-muted small"><%= gmail_delegation.email %></div>
                  <% else %>
                    <span class="text-muted small">Not linked</span>
                  <% end %>
                </td>
                <td class="text-end">
                  <% if user.is_admin %>
                    <span class="badge text-bg-dark me-1">Admin</span>
                  <% end %>
                  <% if user.is_pending %>
                    <span class="badge text-bg-warning">Pending</span>
                  <% else %>
                    <span class="badge text-bg-success">Active</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="p-4 text-center text-muted">No members yet.</div>
      <% end %>
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="card-header">
      <h3 class="h6 mb-0">Pending invitations</h3>
    </div>
    <div class="card-body p-0">
      <% if @pending_invitations.any? %>
        <ul class="list-group list-group-flush mb-0">
          <% @pending_invitations.each do |inv| %>
            <li class="list-group-item d-flex justify-content-between align-items-center">
              <div>
                <div class="fw-semibold"><%= inv.email %></div>
                <div class="small text-muted">
                  Invited by <%= inv.invited_by_user.display_name %> ·
                  sent <%= time_ago_in_words(inv.created_at) %> ago ·
                  <% if inv.expired? %>
                    <span class="text-danger">expired</span>
                  <% else %>
                    expires <%= time_ago_in_words(inv.expires_at) %> from now
                  <% end %>
                </div>
              </div>
              <%= button_to "Revoke", invitation_path(inv),
                    method: :delete,
                    class: "btn btn-sm btn-outline-danger",
                    form: { class: "m-0", data: { turbo_confirm: "Revoke the pending invitation for #{inv.email}?" } } %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="p-3 text-center text-muted small">No pending invitations.</div>
      <% end %>
    </div>
  </div>

  <div class="modal fade" id="inviteUserModal" tabindex="-1" aria-labelledby="inviteUserModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <% blockers = Invitation.send_blockers %>
        <% if blockers.any? %>
          <div class="modal-header">
            <h5 class="modal-title" id="inviteUserModalLabel">Invitations aren't ready to send</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <p class="mb-2">An admin needs to finish setting up the app before invitations can go out:</p>
            <ul class="mb-0">
              <% blockers.each do |reason| %>
                <li><%= reason %></li>
              <% end %>
            </ul>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
          </div>
        <% else %>
        <%= form_with model: @invitation, url: invitations_path, local: true do |f| %>
          <div class="modal-header">
            <h5 class="modal-title" id="inviteUserModalLabel">Invite a user to <%= @tenant.name %></h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <div class="mb-0">
              <%= f.label :email, "Email address", class: "form-label" %>
              <%= f.email_field :email, class: "form-control", placeholder: "name@example.com", required: true %>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <%= f.submit "Send invite", class: "btn btn-primary" %>
          </div>
        <% end %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
