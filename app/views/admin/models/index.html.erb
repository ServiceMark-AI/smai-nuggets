<% content_for :title, "LLM Models" %>

<h1 class="h3 mb-3">LLM Models</h1>

<div class="card shadow-sm">
  <div class="card-body p-0">
    <% if @models.any? %>
      <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th>Provider</th>
            <th>Name</th>
            <th>Family</th>
            <th class="text-end">Context</th>
            <th class="text-end">Max output</th>
          </tr>
        </thead>
        <tbody>
          <% @models.each do |m| %>
            <tr>
              <td><%= m.provider %></td>
              <td><%= m.name %></td>
              <td><%= m.family %></td>
              <td class="text-end"><%= number_with_delimiter(m.context_window) if m.context_window %></td>
              <td class="text-end"><%= number_with_delimiter(m.max_output_tokens) if m.max_output_tokens %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-4 text-center text-muted">No models loaded. Run <code>bin/rails ruby_llm:load_models</code>.</div>
    <% end %>
  </div>
</div>
