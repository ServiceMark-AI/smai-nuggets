<% content_for :title, @organization.name %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0"><%= @organization.name %></h1>
  <%= link_to "← Back to #{@organization.tenant.name}", admin_tenant_path(@organization.tenant), class: "btn btn-sm btn-outline-secondary" %>
</div>

<div class="row g-3">
  <div class="col-lg-6">
    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <dl class="row mb-0">
          <dt class="col-sm-4">Tenant</dt>
          <dd class="col-sm-8"><%= link_to @organization.tenant.name, admin_tenant_path(@organization.tenant) %></dd>

          <dt class="col-sm-4">Parent</dt>
          <dd class="col-sm-8">
            <% if @organization.parent %>
              <%= link_to @organization.parent.name, admin_organization_path(@organization.parent) %>
            <% else %>
              <span class="text-muted">— (top-level)</span>
            <% end %>
          </dd>

          <dt class="col-sm-4">Children</dt>
          <dd class="col-sm-8">
            <% if @children.any? %>
              <ul class="list-unstyled mb-0">
                <% @children.each do |child| %>
                  <li><%= link_to child.name, admin_organization_path(child) %></li>
                <% end %>
              </ul>
            <% else %>
              <span class="text-muted">—</span>
            <% end %>
          </dd>

          <dt class="col-sm-4">Created</dt>
          <dd class="col-sm-8"><%= @organization.created_at.to_fs(:long) %></dd>
        </dl>
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-header"><h2 class="h6 mb-0">Location</h2></div>
      <div class="card-body">
        <% if @location %>
          <dl class="row mb-0">
            <dt class="col-sm-4">Display name</dt>
            <dd class="col-sm-8"><%= @location.display_name %></dd>
            <dt class="col-sm-4">Address</dt>
            <dd class="col-sm-8">
              <%= @location.address_line_1 %><br>
              <% if @location.address_line_2.present? %><%= @location.address_line_2 %><br><% end %>
              <%= "#{@location.city}, #{@location.state} #{@location.postal_code}" %>
            </dd>
            <dt class="col-sm-4">Phone</dt>
            <dd class="col-sm-8"><%= @location.phone_number %></dd>
            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">
              <% if @location.is_active %>
                <span class="badge text-bg-success">Active</span>
              <% else %>
                <span class="badge text-bg-secondary">Inactive</span>
              <% end %>
            </dd>
          </dl>
        <% else %>
          <p class="text-muted mb-0">No location attached.</p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="card shadow-sm">
      <div class="card-header"><h2 class="h6 mb-0">Members (<%= @members.size %>)</h2></div>
      <div class="card-body p-0">
        <% if @members.any? %>
          <table class="table mb-0 align-middle">
            <thead class="table-light">
              <tr>
                <th>Email</th>
                <th>Name</th>
                <th>Role</th>
              </tr>
            </thead>
            <tbody>
              <% @members.each do |user| %>
                <% role = user.organizational_members.find_by(organization: @organization)&.role %>
                <tr>
                  <td><%= user.email %></td>
                  <td><%= user.full_name || content_tag(:span, "—", class: "text-muted") %></td>
                  <td><span class="badge text-bg-secondary"><%= role %></span></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <div class="p-3 text-center text-muted small">No members.</div>
        <% end %>
      </div>
    </div>
  </div>
</div>
