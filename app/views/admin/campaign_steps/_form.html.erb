<%= form_with model: campaign_step, url: form_url, method: form_method, local: true do |f| %>
  <% if campaign_step.errors.any? %>
    <div class="alert alert-danger">
      <h6 class="alert-heading mb-2"><%= pluralize(campaign_step.errors.count, "error") %> prevented this step from being saved:</h6>
      <ul class="mb-0">
        <% campaign_step.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= f.hidden_field :sequence_number %>

  <div class="mb-3">
    <label class="form-label">Offset</label>
    <div class="row g-2">
      <div class="col-4">
        <div class="input-group">
          <%= f.number_field :offset_days, value: campaign_step.offset_days, min: 0, class: "form-control" %>
          <span class="input-group-text">d</span>
        </div>
      </div>
      <div class="col-4">
        <div class="input-group">
          <%= f.number_field :offset_hours, value: campaign_step.offset_hours, min: 0, max: 23, class: "form-control" %>
          <span class="input-group-text">h</span>
        </div>
      </div>
      <div class="col-4">
        <div class="input-group">
          <%= f.number_field :offset_minutes, value: campaign_step.offset_minutes, min: 0, max: 59, class: "form-control" %>
          <span class="input-group-text">m</span>
        </div>
      </div>
    </div>
    <div class="form-text">
      <% if campaign_step.offset_min.to_i > 0 %>
        <%= humanize_offset_minutes(campaign_step.offset_min) %> after the previous step.
      <% else %>
        0 across all three fields = sends immediately.
      <% end %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :template_subject, "Subject", class: "form-label" %>
    <%= f.text_field :template_subject, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :template_body, "Body", class: "form-label" %>
    <%= f.text_area :template_body, class: "form-control", rows: 8 %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_campaign_revision_path(campaign, revision), class: "btn btn-outline-secondary" %>
  </div>
<% end %>
