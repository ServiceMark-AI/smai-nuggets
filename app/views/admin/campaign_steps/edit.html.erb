<% content_for :title, "Edit Step" %>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb mb-0">
    <li class="breadcrumb-item"><%= link_to "Campaigns", admin_campaigns_path %></li>
    <li class="breadcrumb-item"><%= link_to @campaign.name, admin_campaign_path(@campaign) %></li>
    <li class="breadcrumb-item"><%= link_to "Revision ##{@revision.revision_number}", admin_campaign_revision_path(@campaign, @revision) %></li>
    <li class="breadcrumb-item active" aria-current="page">Edit Step</li>
  </ol>
</nav>
<h1 class="h3 mb-4">Edit Step</h1>

<div class="row g-4">
  <div class="col-12 col-lg-7">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <%= render "admin/campaign_steps/form",
              campaign: @campaign,
              revision: @revision,
              campaign_step: @campaign_step,
              form_url: admin_campaign_revision_step_path(@campaign, @revision, @campaign_step),
              form_method: :patch %>
      </div>
    </div>
  </div>
  <div class="col-12 col-lg-5">
    <%= render "merge_fields_reference" %>
  </div>
</div>
