<% content_for :title, "Edit Step" %>

<div class="row">
  <div class="col-md-8 col-lg-6">
    <nav aria-label="breadcrumb" class="mb-3">
      <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><%= link_to "Campaigns", admin_campaigns_path %></li>
        <li class="breadcrumb-item"><%= link_to @campaign.name, admin_campaign_path(@campaign) %></li>
        <li class="breadcrumb-item"><%= link_to "Edit", edit_admin_campaign_path(@campaign) %></li>
        <li class="breadcrumb-item active" aria-current="page">Edit Step</li>
      </ol>
    </nav>
    <h1 class="h3 mb-4">Edit Step</h1>

    <div class="card shadow-sm">
      <div class="card-body p-4">
        <%= render "admin/campaign_steps/form",
            campaign: @campaign,
            campaign_step: @campaign_step,
            form_url: admin_campaign_step_path(@campaign, @campaign_step),
            form_method: :patch %>
      </div>
    </div>
  </div>
</div>
