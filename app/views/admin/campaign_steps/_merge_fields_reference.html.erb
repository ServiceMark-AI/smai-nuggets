<section>
  <h2 class="h5 mb-2">Available merge fields</h2>
  <p class="text-muted small mb-3">
    Use these tokens anywhere in the Subject or Body. They're replaced at send time with values from the proposal, the proposal owner, and the organization's office location. The right column shows what each token looks like with sample data.
  </p>
  <div class="card shadow-sm">
    <div class="card-body p-3">
      <% MailGenerator::MERGE_FIELD_GROUPS.each_with_index do |(group_name, keys), index| %>
        <h6 class="text-uppercase text-muted small <%= index.zero? ? 'mb-1' : 'mt-3 mb-1' %>"><%= group_name %></h6>
        <table class="table table-sm mb-0">
          <tbody>
            <% keys.each do |key| %>
              <tr>
                <td style="width: 40%;"><code>{<%= key %>}</code></td>
                <td class="text-muted small"><%= MailGenerator::SAMPLE_VALUES[key] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    </div>
  </div>
</section>
