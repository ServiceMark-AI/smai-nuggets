<% content_for :title, @job_type.name %>

<%= link_to "← All Job Types", admin_job_types_path, class: "small text-muted" %>

<div class="d-flex justify-content-between align-items-center mt-2 mb-4">
  <h1 class="h3 mb-0"><%= @job_type.name %></h1>
  <div class="d-flex gap-2">
    <%= link_to "Edit", edit_admin_job_type_path(@job_type), class: "btn btn-outline-primary btn-sm" %>
    <%= button_to "Delete", admin_job_type_path(@job_type), method: :delete, class: "btn btn-outline-danger btn-sm",
          form: { data: { turbo_confirm: "Delete this job type? Existing job proposals stay but lose their job type reference." } } %>
  </div>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-body">
    <dl class="row mb-0">
      <dt class="col-sm-3">Name</dt>
      <dd class="col-sm-9"><%= @job_type.name %></dd>

      <dt class="col-sm-3">Type code</dt>
      <dd class="col-sm-9"><code><%= @job_type.type_code %></code></dd>

      <dt class="col-sm-3">Description</dt>
      <dd class="col-sm-9"><%= simple_format(@job_type.description.presence || content_tag(:span, "—", class: "text-muted").to_s) %></dd>

      <dt class="col-sm-3">Job proposals</dt>
      <dd class="col-sm-9"><%= @job_type.job_proposals.count %></dd>
    </dl>
  </div>
</div>

<div class="card shadow-sm">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h2 class="h5 mb-0">Scenarios (<%= @scenarios.size %>)</h2>
    <%= link_to "+ New Scenario", new_admin_job_type_scenario_path(@job_type), class: "btn btn-sm btn-primary" %>
  </div>
  <div class="card-body p-0">
    <% if @scenarios.any? %>
      <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th>Code</th>
            <th>Short name</th>
            <th>Description</th>
            <th>Campaign</th>
          </tr>
        </thead>
        <tbody>
          <% @scenarios.each do |s| %>
            <tr>
              <td><code><%= s.code %></code></td>
              <td><%= link_to s.short_name, admin_scenario_path(s) %></td>
              <td><%= truncate(s.description.to_s, length: 120, separator: " ").presence || content_tag(:span, "—", class: "text-muted") %></td>
              <td>
                <% if s.campaign %>
                  <%= link_to s.campaign.name, admin_campaign_path(s.campaign) %>
                <% else %>
                  <span class="text-muted">—</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-4 text-center text-muted">
        No scenarios yet. <%= link_to "Add the first one", new_admin_job_type_scenario_path(@job_type) %>.
      </div>
    <% end %>
  </div>
</div>
