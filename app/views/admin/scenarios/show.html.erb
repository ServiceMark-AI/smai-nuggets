<% content_for :title, @scenario.short_name %>

<%= link_to "← #{@job_type.name}", admin_job_type_path(@job_type), class: "small text-muted" %>

<div class="d-flex justify-content-between align-items-center mt-2 mb-4">
  <div>
    <h1 class="h3 mb-0"><%= @scenario.short_name %></h1>
    <div class="text-muted small">in <%= link_to @job_type.name, admin_job_type_path(@job_type) %></div>
  </div>
  <div class="d-flex gap-2">
    <%= link_to "Edit", edit_admin_scenario_path(@scenario), class: "btn btn-outline-primary btn-sm" %>
    <%= button_to "Delete", admin_scenario_path(@scenario), method: :delete, class: "btn btn-outline-danger btn-sm",
          form: { data: { turbo_confirm: "Delete this scenario?" } } %>
  </div>
</div>

<div class="card shadow-sm">
  <div class="card-body">
    <dl class="row mb-0">
      <dt class="col-sm-3">Code</dt>
      <dd class="col-sm-9"><code><%= @scenario.code %></code></dd>

      <dt class="col-sm-3">Short name</dt>
      <dd class="col-sm-9"><%= @scenario.short_name %></dd>

      <dt class="col-sm-3">Description</dt>
      <dd class="col-sm-9"><%= simple_format(@scenario.description.presence || content_tag(:span, "—", class: "text-muted").to_s) %></dd>

      <dt class="col-sm-3">Job type</dt>
      <dd class="col-sm-9"><%= link_to @job_type.name, admin_job_type_path(@job_type) %></dd>

      <dt class="col-sm-3">Campaign</dt>
      <dd class="col-sm-9">
        <% if @scenario.campaign %>
          <%= link_to @scenario.campaign.name, admin_campaign_path(@scenario.campaign) %>
          <span class="badge text-bg-secondary ms-2"><%= @scenario.campaign.status %></span>
        <% else %>
          <span class="text-muted">— not yet attached</span>
        <% end %>
      </dd>
    </dl>
  </div>
</div>
