<%= form_with model: @scenario, url: form_url, method: form_method, local: true do |f| %>
  <% if @scenario.errors.any? %>
    <div class="alert alert-danger">
      <strong>Please fix the following:</strong>
      <ul class="mb-0">
        <% @scenario.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <label class="form-label">Job type</label>
    <input type="text" value="<%= @job_type.name %>" class="form-control" disabled>
    <div class="form-text">Scenarios belong to one job type and can't be reassigned.</div>
  </div>

  <div class="mb-3">
    <%= f.label :code, class: "form-label" %>
    <%= f.text_field :code, class: "form-control", required: true, maxlength: 64,
          placeholder: "e.g. sewage_backup" %>
    <div class="form-text">Short identifier, unique within the job type.</div>
  </div>

  <div class="mb-3">
    <%= f.label :short_name, "Short name", class: "form-label" %>
    <%= f.text_field :short_name, class: "form-control", required: true,
          placeholder: "e.g. Sewage backup" %>
  </div>

  <div class="mb-3">
    <%= f.label :description, "Authoring hypothesis", class: "form-label" %>
    <%= f.text_area :description, rows: 3, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :industry_classification, "Industry classification", class: "form-label" %>
    <%= f.text_field :industry_classification, class: "form-control",
          placeholder: "e.g. IICRC S520 Mold Remediation" %>
    <div class="form-text">Free-form. The standard or category this scenario fits under.</div>
  </div>

  <div class="mb-3">
    <%= f.label :campaign_id, "Campaign", class: "form-label" %>
    <% if @scenario.persisted? %>
      <% scoped_campaigns = @scenario.attributed_campaigns.order(:name) %>
      <%= f.collection_select :campaign_id, scoped_campaigns, :id, :name,
            { include_blank: "— No campaign yet —" },
            class: "form-select" %>
      <div class="form-text">
        Only campaigns attributed to this scenario are shown.
        <% if scoped_campaigns.empty? %>
          None yet — create one from the
          <%= link_to "Campaigns", admin_campaigns_path %>
          page and pick this scenario as the attribution.
        <% end %>
      </div>
    <% else %>
      <input type="text" class="form-control" disabled value="— Save the scenario first —">
      <div class="form-text">A campaign can be attached after the scenario exists.</div>
    <% end %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit submit_label, class: "btn btn-primary" %>
    <%= link_to "Cancel", cancel_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
