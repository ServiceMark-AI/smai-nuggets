<% content_for :title, "New Location for #{@tenant.name}" %>

<%= render "shared/admin_breadcrumb",
      tenant: @tenant,
      location: @location,
      current: :location %>

<h1 class="h3 mb-3">New Location for <%= @tenant.name %></h1>

<p class="text-muted">
  Required fields below feed the email signature block. The location stays
  inactive until every required field is present.
</p>

<%= render "locations/form",
      location_form_url: admin_tenant_locations_path(@tenant),
      location_form_method: :post,
      submit_label: "Create Location",
      cancel_url: admin_tenant_path(@tenant) %>
