<% content_for :title, "Application Mailbox" %>

<h1 class="h3 mb-1">Application Mailbox</h1>
<p class="text-muted mb-4">
  The single OAuth-connected Gmail account the app uses to send Devise
  emails (password resets, etc.) and tenant invitations. Distinct from
  the per-user Gmail connections used for on-behalf-of operator sends.
</p>

<div class="card shadow-sm">
  <div class="card-body">
    <% if @mailbox %>
      <dl class="row mb-3">
        <dt class="col-sm-3">Connected as</dt>
        <dd class="col-sm-9">
          <%= @mailbox.email %>
          <span class="badge text-bg-success ms-2">Connected</span>
        </dd>

        <dt class="col-sm-3">Provider</dt>
        <dd class="col-sm-9"><%= @mailbox.provider %></dd>

        <dt class="col-sm-3">Connected at</dt>
        <dd class="col-sm-9"><%= @mailbox.created_at.to_fs(:long) %></dd>

        <dt class="col-sm-3">Token expires</dt>
        <dd class="col-sm-9">
          <% if @mailbox.expires_at %>
            <%= @mailbox.expires_at.to_fs(:long) %>
            <% if @mailbox.expired? %>
              <span class="badge text-bg-warning ms-2">Expired — will refresh on next send</span>
            <% end %>
          <% else %>
            <span class="text-muted">—</span>
          <% end %>
        </dd>
      </dl>

      <div class="d-flex gap-2 align-items-center">
        <% if google_oauth_configured? %>
          <%# target=application_mailbox is in the URL query string (not a
              hidden body field) so OmniAuth captures it into omniauth.params
              reliably across the OAuth round-trip — body-only params can be
              dropped depending on Rack/CSRF interactions. %>
          <%= form_with url: "/auth/google_oauth2?target=application_mailbox", method: :post, local: true, class: "d-inline" do |f| %>
            <%= f.submit "Reconnect", class: "btn btn-outline-primary btn-sm" %>
          <% end %>
        <% else %>
          <button type="button" class="btn btn-outline-primary btn-sm" disabled>Reconnect</button>
          <span class="small text-muted">
            Set <code><%= missing_google_oauth_env_vars.join("</code>, <code>").html_safe %></code> to enable.
          </span>
        <% end %>
        <%= button_to "Disconnect", admin_application_mailbox_path,
              method: :delete, class: "btn btn-outline-danger btn-sm",
              form: { class: "d-inline", data: { turbo_confirm: "Disconnect the application mailbox? Outbound emails will stop being sent until you reconnect." } } %>
      </div>
    <% else %>
      <p class="mb-3">
        <span class="badge text-bg-secondary">Not connected</span>
        Outbound mail will be dropped until a mailbox is connected.
      </p>
      <% if google_oauth_configured? %>
        <%= form_with url: "/auth/google_oauth2?target=application_mailbox", method: :post, local: true, class: "d-inline" do |f| %>
          <%= f.submit "Connect a Google account", class: "btn btn-primary" %>
        <% end %>
      <% else %>
        <button type="button" class="btn btn-primary" disabled>Connect a Google account</button>
        <div class="alert alert-warning mt-3 mb-0 small">
          <strong>Google OAuth isn't configured yet.</strong>
          Set <code><%= missing_google_oauth_env_vars.join("</code> and <code>").html_safe %></code>
          in your environment (see <code>.env.example</code>), then restart the app.
        </div>
      <% end %>
    <% end %>
  </div>
</div>
