<% content_for :title, "Messages" %>

<h1 class="h3 mb-3">Messages <span class="text-muted small">(latest 200)</span></h1>

<div class="card shadow-sm">
  <div class="card-body p-0">
    <% if @messages.any? %>
      <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th>Chat</th>
            <th>Role</th>
            <th>Content</th>
            <th>Model</th>
            <th class="text-end">In/Out</th>
            <th>Created</th>
          </tr>
        </thead>
        <tbody>
          <% @messages.each do |m| %>
            <tr>
              <td><%= link_to "##{m.chat_id}", admin_chat_path(m.chat_id) %></td>
              <td><span class="badge text-bg-secondary"><%= m.role %></span></td>
              <td><%= truncate(m.content.to_s, length: 120) %></td>
              <td><%= m.model&.name || "—" %></td>
              <td class="text-end"><%= m.input_tokens || 0 %> / <%= m.output_tokens || 0 %></td>
              <td><%= l(m.created_at, format: :short) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-4 text-center text-muted">No messages yet.</div>
    <% end %>
  </div>
</div>
