<% content_for :title, "Edit Campaign" %>

<h1 class="h3 mb-4">Edit Campaign</h1>

<div class="row mb-4">
  <div class="col-md-8 col-lg-6">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <%= render "form", campaign: @campaign %>
      </div>
    </div>
  </div>
</div>

<p class="text-muted">
  To change the email content or cadence, head to the campaign page and create a new draft revision.
  <%= link_to "Back to #{@campaign.name}", admin_campaign_path(@campaign), class: "btn btn-sm btn-outline-secondary ms-2" %>
</p>
