<% content_for :title, @campaign.name %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0"><%= @campaign.name %></h1>
  <div class="d-flex gap-2">
    <% if @campaign.status_draft? %>
      <%= button_to "Approve", approve_admin_campaign_path(@campaign), method: :patch, class: "btn btn-sm btn-success", form: { class: "m-0" } %>
    <% elsif @campaign.status_approved? %>
      <%= button_to "Pause", pause_admin_campaign_path(@campaign), method: :patch, class: "btn btn-sm btn-warning", form: { class: "m-0" } %>
    <% elsif @campaign.status_paused? %>
      <%= button_to "Unpause", resume_admin_campaign_path(@campaign), method: :patch, class: "btn btn-sm btn-success", form: { class: "m-0" } %>
    <% end %>
    <%= link_to "Edit", edit_admin_campaign_path(@campaign), class: "btn btn-sm btn-outline-primary" %>
    <%= link_to "All campaigns", admin_campaigns_path, class: "btn btn-sm btn-outline-secondary" %>
    <%# Soft-delete via discard. Disabled when any active/drafting run
        references this template — Campaign#ensure_no_live_runs! also
        refuses server-side. %>
    <% live_runs = @campaign.instances.where(status: %i[active drafting]).exists? %>
    <%= button_to "Delete", admin_campaign_path(@campaign),
          method: :delete,
          class: "btn btn-sm btn-outline-danger",
          form: { class: "m-0", data: { turbo_confirm: "Move this campaign to trash? An admin can restore it from /admin/trash." } },
          disabled: live_runs,
          title: live_runs ? "Pause or close all live runs before deleting." : nil %>
  </div>
</div>

<div class="card shadow-sm mb-3">
  <div class="card-body">
    <% status_class = case @campaign.status when "approved" then "text-bg-success" when "paused" then "text-bg-warning" else "text-bg-secondary" end %>
    <dl class="row mb-0">
      <dt class="col-sm-3">Status</dt>
      <dd class="col-sm-9">
        <span class="badge <%= status_class %>"><%= @campaign.status %></span>
      </dd>

      <% if @campaign.status_approved? && @campaign.approved_by_user %>
        <dt class="col-sm-3">Approved by</dt>
        <dd class="col-sm-9">
          <%= @campaign.approved_by_user.display_name %>
          <% if @campaign.approved_at %>
            <span class="text-muted small">on <%= @campaign.approved_at.to_fs(:long) %></span>
          <% end %>
        </dd>
      <% elsif @campaign.status_paused? %>
        <% if @campaign.paused_by_user %>
          <dt class="col-sm-3">Paused by</dt>
          <dd class="col-sm-9">
            <%= @campaign.paused_by_user.display_name %>
            <% if @campaign.paused_at %>
              <span class="text-muted small">on <%= @campaign.paused_at.to_fs(:long) %></span>
            <% end %>
          </dd>
        <% end %>
        <% if @campaign.approved_by_user %>
          <dt class="col-sm-3">Originally approved by</dt>
          <dd class="col-sm-9">
            <%= @campaign.approved_by_user.display_name %>
            <% if @campaign.approved_at %>
              <span class="text-muted small">on <%= @campaign.approved_at.to_fs(:long) %></span>
            <% end %>
          </dd>
        <% end %>
      <% end %>

      <dt class="col-sm-3">Scenario</dt>
      <dd class="col-sm-9">
        <% if @campaign.attributed_to.is_a?(Scenario) %>
          <% scenario = @campaign.attributed_to %>
          <%= link_to scenario.short_name, admin_scenario_path(scenario) %>
          <span class="text-muted small">in <%= link_to scenario.job_type.name, admin_job_type_path(scenario.job_type) %></span>
        <% else %>
          <span class="text-muted">— not attributed to a scenario</span>
        <% end %>
      </dd>
    </dl>
  </div>
</div>

<%# --- Active revision (read-only step list) -------------------------------- %>
<%
  active_revision = @campaign.active_revision
  drafting_revision = @campaign.revisions.find_by(status: :drafting)
%>
<div class="card shadow-sm mb-4">
  <div class="card-header d-flex justify-content-between align-items-center">
    <div>
      <h2 class="h5 mb-0">Active steps</h2>
      <% if active_revision %>
        <div class="small text-muted mt-1">
          From <%= link_to "Revision ##{active_revision.revision_number}", admin_campaign_revision_path(@campaign, active_revision) %>.
          To make changes, create a new draft revision below.
        </div>
      <% end %>
    </div>
  </div>
  <div class="card-body p-0">
    <% if active_revision&.steps&.any? %>
      <table class="table mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th style="width: 48px;">#</th>
            <th>Step</th>
            <th class="text-end" style="width: 180px;">Offset</th>
          </tr>
        </thead>
        <tbody>
          <% active_revision.steps.each do |step| %>
            <tr>
              <td><%= step.sequence_number %></td>
              <td>
                <% rendered = MailGenerator.preview(campaign_step: step) %>
                <div class="fw-semibold"><%= rendered.subject.presence || content_tag(:span, "(no subject)", class: "text-muted fst-italic") %></div>
                <% if rendered.body.present? %>
                  <div class="text-muted small mt-1" style="white-space: pre-wrap;"><%= rendered.body %></div>
                <% else %>
                  <div class="text-muted small fst-italic mt-1">(no body)</div>
                <% end %>
              </td>
              <td class="text-end"><%= humanize_offset_minutes(step.offset_min) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% elsif active_revision %>
      <div class="p-4 text-center text-muted">No steps in the active revision yet.</div>
    <% else %>
      <div class="p-4 text-center text-muted">No active revision.</div>
    <% end %>
  </div>
</div>

<%# --- Revisions ----------------------------------------------------------- %>
<div class="card shadow-sm mb-4" id="revisions">
  <div class="card-header d-flex justify-content-between align-items-start">
    <div>
      <h2 class="h5 mb-0">Revisions</h2>
      <div class="small text-muted mt-1">
        Each edit to the campaign content lives in its own revision. The active revision is what new customer sequences will use.
      </div>
    </div>
    <% if drafting_revision %>
      <%= link_to "Continue draft ##{drafting_revision.revision_number}",
            admin_campaign_revision_path(@campaign, drafting_revision),
            class: "btn btn-primary btn-sm" %>
    <% else %>
      <%= button_to "Create new revision",
            admin_campaign_revisions_path(@campaign),
            method: :post,
            class: "btn btn-primary btn-sm",
            form: { class: "m-0" } %>
    <% end %>
  </div>
  <div class="card-body p-0">
    <% if @campaign.revisions.any? %>
      <table class="table mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th>Revision</th>
            <th>Status</th>
            <th>Created by</th>
            <th>Approved by</th>
            <th class="text-end">Steps</th>
          </tr>
        </thead>
        <tbody>
          <% @campaign.revisions.includes(:created_by_user, :approved_by_user, :steps).reorder(revision_number: :desc).each do |rev| %>
            <% rev_status_class = case rev.status when "active" then "text-bg-success" when "drafting" then "text-bg-secondary" else "text-bg-dark" end %>
            <tr>
              <td>
                <%= link_to "Revision ##{rev.revision_number}", admin_campaign_revision_path(@campaign, rev) %>
              </td>
              <td><span class="badge <%= rev_status_class %>"><%= rev.status %></span></td>
              <td>
                <%= rev.created_by_user.display_name %>
                <div class="text-muted small"><%= rev.created_at.to_fs(:long) %></div>
              </td>
              <td>
                <% if rev.approved_by_user %>
                  <%= rev.approved_by_user.display_name %>
                  <% if rev.approved_at %>
                    <div class="text-muted small"><%= rev.approved_at.to_fs(:long) %></div>
                  <% end %>
                <% else %>
                  <span class="text-muted">—</span>
                <% end %>
              </td>
              <td class="text-end"><%= rev.steps.size %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-4 text-center text-muted">No revisions yet.</div>
    <% end %>
  </div>
</div>
