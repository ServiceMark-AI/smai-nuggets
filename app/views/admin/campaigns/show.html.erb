<% content_for :title, @campaign.name %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h1 class="h3 mb-1"><%= @campaign.name %></h1>
    <% klass = case @campaign.status when "approved" then "text-bg-success" when "paused" then "text-bg-warning" else "text-bg-secondary" end %>
    <span class="badge <%= klass %>"><%= @campaign.status %></span>
  </div>
  <div class="d-flex gap-2">
    <% if @campaign.status_new? %>
      <%= button_to "Approve", approve_admin_campaign_path(@campaign), method: :patch, class: "btn btn-sm btn-success", form: { class: "m-0" } %>
    <% elsif @campaign.status_approved? %>
      <%= button_to "Pause", pause_admin_campaign_path(@campaign), method: :patch, class: "btn btn-sm btn-warning", form: { class: "m-0" } %>
    <% end %>
    <%= link_to "Edit", edit_admin_campaign_path(@campaign), class: "btn btn-sm btn-outline-primary" %>
    <%= link_to "All campaigns", admin_campaigns_path, class: "btn btn-sm btn-outline-secondary" %>
  </div>
</div>

<div class="card shadow-sm mb-3">
  <div class="card-body">
    <dl class="row mb-0">
      <dt class="col-sm-3">Status</dt>
      <dd class="col-sm-9">
        <span class="badge <%= klass %>"><%= @campaign.status %></span>
      </dd>

      <dt class="col-sm-3">Scenario</dt>
      <dd class="col-sm-9">
        <% if @campaign.attributed_to.is_a?(Scenario) %>
          <% scenario = @campaign.attributed_to %>
          <%= link_to scenario.short_name, admin_scenario_path(scenario) %>
          <span class="text-muted small">in <%= link_to scenario.job_type.name, admin_job_type_path(scenario.job_type) %></span>
        <% else %>
          <span class="text-muted">— not attributed to a scenario</span>
        <% end %>
      </dd>
    </dl>
  </div>
</div>

<%= render "steps", campaign: @campaign %>
