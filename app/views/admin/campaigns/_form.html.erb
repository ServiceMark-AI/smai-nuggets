<%= form_with model: [:admin, campaign], local: true do |f| %>
  <% if campaign.errors.any? %>
    <div class="alert alert-danger">
      <h6 class="alert-heading mb-2"><%= pluralize(campaign.errors.count, "error") %> prevented this campaign from being saved:</h6>
      <ul class="mb-0">
        <% campaign.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control", autofocus: true %>
  </div>

  <div class="mb-3">
    <%= f.label :attributed_scenario_id, "Attributed to scenario", class: "form-label" %>
    <% scenario_options = Scenario.includes(:job_type).order("job_types.name", :short_name).map { |s| ["#{s.job_type.name} — #{s.short_name}", s.id] } %>
    <%= f.select :attributed_scenario_id, scenario_options,
          { include_blank: "— Not attributed —" },
          class: "form-select" %>
    <div class="form-text">Optional. Only scenarios are supported today; other attribution targets (tenant, job type) will be added later.</div>
  </div>

  <% cancel_path = campaign.persisted? ? admin_campaign_path(campaign) : admin_campaigns_path %>
  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", cancel_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
