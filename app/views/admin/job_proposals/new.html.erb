<% content_for :title, "New Job Proposal" %>

<%= link_to "← Back to Job Proposals", job_proposals_path, class: "small text-muted" %>

<h1 class="h3 mt-2 mb-4">New Job Proposal</h1>

<%= form_with model: @job_proposal, url: admin_job_proposals_path, method: :post, local: true do |f| %>
  <% if @job_proposal.errors.any? %>
    <div class="alert alert-danger">
      <strong>Please fix the following:</strong>
      <ul class="mb-0">
        <% @job_proposal.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card shadow-sm mb-4">
    <div class="card-header"><h2 class="h5 mb-0">Organization</h2></div>
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-12">
          <%= f.label :organization_id, "Organization", class: "form-label" %>
          <%= f.collection_select :organization_id, @organization_options, :id, ->(o) { "#{o.tenant.name} — #{o.name}" },
                { include_blank: "— Select an organization —" },
                class: "form-select" %>
          <div class="form-text">Tenant is inferred from the organization.</div>
        </div>
      </div>
    </div>
  </div>

  <div class="card shadow-sm mb-4">
    <div class="card-header"><h2 class="h5 mb-0">Customer</h2></div>
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-2">
          <%= f.label :customer_title, "Title", class: "form-label" %>
          <%= f.text_field :customer_title, class: "form-control" %>
        </div>
        <div class="col-md-5">
          <%= f.label :customer_first_name, "First name", class: "form-label" %>
          <%= f.text_field :customer_first_name, class: "form-control" %>
        </div>
        <div class="col-md-5">
          <%= f.label :customer_last_name, "Last name", class: "form-label" %>
          <%= f.text_field :customer_last_name, class: "form-control" %>
        </div>
        <div class="col-md-12">
          <%= f.label :customer_email, "Email", class: "form-label" %>
          <%= f.email_field :customer_email, class: "form-control" %>
        </div>
        <div class="col-md-3">
          <%= f.label :customer_house_number, "House #", class: "form-label" %>
          <%= f.text_field :customer_house_number, class: "form-control" %>
        </div>
        <div class="col-md-9">
          <%= f.label :customer_street, "Street", class: "form-label" %>
          <%= f.text_field :customer_street, class: "form-control" %>
        </div>
        <div class="col-md-6">
          <%= f.label :customer_city, "City", class: "form-label" %>
          <%= f.text_field :customer_city, class: "form-control" %>
        </div>
        <div class="col-md-2">
          <%= f.label :customer_state, "State", class: "form-label" %>
          <%= f.text_field :customer_state, class: "form-control" %>
        </div>
        <div class="col-md-4">
          <%= f.label :customer_zip, "Zip", class: "form-label" %>
          <%= f.text_field :customer_zip, class: "form-control" %>
        </div>
      </div>
    </div>
  </div>

  <div class="card shadow-sm mb-4">
    <div class="card-header"><h2 class="h5 mb-0">Job</h2></div>
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-6">
          <%= f.label :job_type_id, "Job type", class: "form-label" %>
          <%= f.collection_select :job_type_id, @job_type_options, :id, :name,
                { include_blank: "— None —" },
                class: "form-select" %>
        </div>
        <div class="col-md-6">
          <%= f.label :scenario_id, "Scenario", class: "form-label" %>
          <%= f.collection_select :scenario_id, @scenario_options, :id, ->(s) { "#{s.job_type.name} — #{s.short_name}" },
                { include_blank: "— None —" },
                class: "form-select" %>
          <div class="form-text">A campaign launches when the proposal is saved with a scenario whose campaign is approved.</div>
        </div>
        <div class="col-md-6">
          <%= f.label :proposal_value, "Proposal value", class: "form-label" %>
          <%= f.number_field :proposal_value, step: 0.01, class: "form-control" %>
        </div>
        <div class="col-md-6">
          <%= f.label :internal_reference, "Internal reference", class: "form-label" %>
          <%= f.text_field :internal_reference, class: "form-control" %>
        </div>
      </div>
    </div>
  </div>

  <div class="card shadow-sm mb-4">
    <div class="card-header"><h2 class="h5 mb-0">Loss notes</h2></div>
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-6">
          <%= f.label :loss_reason, "Loss reason", class: "form-label" %>
          <%= f.text_field :loss_reason, class: "form-control",
                placeholder: "e.g. Price, Timing, No response" %>
        </div>
        <div class="col-md-12">
          <%= f.label :loss_notes, "Loss notes", class: "form-label" %>
          <%= f.text_area :loss_notes, rows: 3, class: "form-control" %>
        </div>
      </div>
    </div>
  </div>

  <div class="card shadow-sm mb-4">
    <div class="card-header"><h2 class="h5 mb-0">Ownership</h2></div>
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-6">
          <%= f.label :owner_id, "Owner", class: "form-label" %>
          <%= f.collection_select :owner_id, @owner_options, :id, :email,
                { include_blank: "— Select an owner —" },
                class: "form-select" %>
          <div class="form-text">Pick a user belonging to the chosen organization. Save and edit if the list looks wrong for the org.</div>
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex justify-content-end gap-2">
    <%= link_to "Cancel", job_proposals_path, class: "btn btn-outline-secondary" %>
    <%= f.submit "Create", class: "btn btn-primary" %>
  </div>
<% end %>
