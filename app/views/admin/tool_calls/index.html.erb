<% content_for :title, "Tool Calls" %>

<h1 class="h3 mb-3">Tool Calls <span class="text-muted small">(latest 200)</span></h1>

<div class="card shadow-sm">
  <div class="card-body p-0">
    <% if @tool_calls.any? %>
      <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th>ID</th>
            <th>Message</th>
            <th>Created</th>
          </tr>
        </thead>
        <tbody>
          <% @tool_calls.each do |t| %>
            <tr>
              <td><%= t.id %></td>
              <td><%= t.message_id %></td>
              <td><%= l(t.created_at, format: :short) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-4 text-center text-muted">No tool calls yet.</div>
    <% end %>
  </div>
</div>
