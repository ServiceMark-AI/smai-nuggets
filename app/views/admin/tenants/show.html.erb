<% content_for :title, @tenant.name %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0">Tenant: <%= @tenant.name %></h1>
  <div class="d-flex gap-2">
    <%= link_to "Manage activations", admin_tenant_activations_path(@tenant), class: "btn btn-sm btn-outline-primary" %>
    <%= link_to "All tenants", admin_tenants_path, class: "btn btn-sm btn-outline-secondary" %>
  </div>
</div>

<div class="row g-3">
  <div class="col-lg-7">
    <div class="card shadow-sm mb-3">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h2 class="h5 mb-0">Users (<%= @users.size %>)</h2>
      </div>
      <div class="card-body p-0">
        <% if @users.any? %>
          <table class="table mb-0 align-middle">
            <thead class="table-light">
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Location</th>
                <th class="text-end">Status</th>
              </tr>
            </thead>
            <tbody>
              <% @users.each do |user| %>
                <tr>
                  <td>
                    <% if user.full_name.present? %>
                      <%= user.full_name %>
                    <% else %>
                      <span class="text-muted">—</span>
                    <% end %>
                  </td>
                  <td><%= user.email %></td>
                  <td>
                    <% if user.location %>
                      <%= user.location.display_name %>
                    <% else %>
                      <span class="text-muted">—</span>
                    <% end %>
                  </td>
                  <td class="text-end">
                    <% if user.is_admin %>
                      <span class="badge text-bg-dark me-1">Admin</span>
                    <% end %>
                    <% if user.is_pending %>
                      <span class="badge text-bg-warning">Pending</span>
                    <% else %>
                      <span class="badge text-bg-success">Active</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <div class="p-3 text-center text-muted small">No users yet.</div>
        <% end %>
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h2 class="h5 mb-0">Locations (<%= @locations.size %>)</h2>
        <%= link_to "Add location", new_admin_tenant_location_path(@tenant), class: "btn btn-sm btn-outline-primary" %>
      </div>
      <div class="card-body p-0">
        <% if @locations.any? %>
          <table class="table mb-0 align-middle">
            <thead class="table-light">
              <tr>
                <th>Display name</th>
                <th>City, State</th>
                <th>Phone</th>
                <th class="text-end">Status</th>
              </tr>
            </thead>
            <tbody>
              <% @locations.each do |loc| %>
                <tr>
                  <td><%= loc.display_name %></td>
                  <td><%= [loc.city, loc.state].compact_blank.join(", ") %></td>
                  <td><%= loc.phone_number %></td>
                  <td class="text-end">
                    <% if loc.is_active %>
                      <span class="badge text-bg-success">Active</span>
                    <% else %>
                      <span class="badge text-bg-secondary">Inactive</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <div class="p-3 text-center text-muted small">No locations yet.</div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="card shadow-sm mb-3">
      <div class="card-body p-4">
        <h2 class="h5 mb-3">Invite a user</h2>
        <% blockers = Invitation.send_blockers %>
        <% if blockers.any? %>
          <div class="alert alert-warning mb-0">
            <strong>Invitations aren't ready to send.</strong>
            <ul class="mb-0 mt-2">
              <% blockers.each do |reason| %>
                <li><%= reason %></li>
              <% end %>
            </ul>
          </div>
        <% else %>
          <%= form_with model: @invitation, url: admin_tenant_invitations_path(@tenant), local: true do |f| %>
            <div class="input-group">
              <%= f.email_field :email, class: "form-control", placeholder: "name@example.com", required: true %>
              <%= f.submit "Send invite", class: "btn btn-primary" %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-header"><h3 class="h6 mb-0">Pending invitations</h3></div>
      <div class="card-body p-0">
        <% if @pending_invitations.any? %>
          <ul class="list-group list-group-flush mb-0">
            <% @pending_invitations.each do |inv| %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                  <div class="fw-semibold"><%= inv.email %></div>
                  <div class="small text-muted">Sent <%= time_ago_in_words(inv.created_at) %> ago · expires <%= time_ago_in_words(inv.expires_at) %> from now</div>
                </div>
                <%= button_to "Revoke", admin_tenant_invitation_path(@tenant, inv),
                      method: :delete,
                      class: "btn btn-sm btn-outline-danger",
                      form: { class: "m-0", data: { turbo_confirm: "Revoke the pending invitation for #{inv.email}?" } } %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="p-3 text-center text-muted small">No pending invitations.</div>
        <% end %>
      </div>
    </div>
  </div>
</div>
