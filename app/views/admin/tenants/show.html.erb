<% content_for :title, @tenant.name %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0"><%= @tenant.name %></h1>
  <div class="d-flex gap-2">
    <%= link_to "Manage activations", admin_tenant_activations_path(@tenant), class: "btn btn-sm btn-outline-primary" %>
    <%= link_to "All tenants", admin_tenants_path, class: "btn btn-sm btn-outline-secondary" %>
  </div>
</div>

<div class="row g-3">
  <div class="col-lg-7">
    <div class="card shadow-sm mb-3">
      <div class="card-body p-4">
        <h2 class="h5 mb-3">Organizations</h2>
        <% roots = @tenant.organizations.where(parent_id: nil).order(:name) %>
        <% if roots.any? %>
          <ul class="list-unstyled mb-0">
            <% roots.each do |org| %>
              <%= render "organization_node", organization: org %>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted mb-0">No organizations.</p>
        <% end %>
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-header">
        <h2 class="h5 mb-0">Users (<%= @users.size %>)</h2>
      </div>
      <div class="card-body p-0">
        <% if @users.any? %>
          <table class="table mb-0 align-middle">
            <thead class="table-light">
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th class="text-end">Status</th>
              </tr>
            </thead>
            <tbody>
              <% @users.each do |user| %>
                <tr>
                  <td>
                    <% if user.full_name.present? %>
                      <%= user.full_name %>
                    <% else %>
                      <span class="text-muted">—</span>
                    <% end %>
                  </td>
                  <td><%= user.email %></td>
                  <td class="text-end">
                    <% if user.is_admin %>
                      <span class="badge text-bg-dark me-1">Admin</span>
                    <% end %>
                    <% if user.is_pending %>
                      <span class="badge text-bg-warning">Pending</span>
                    <% else %>
                      <span class="badge text-bg-success">Active</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <div class="p-3 text-center text-muted small">No users yet.</div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="card shadow-sm mb-3">
      <div class="card-body p-4">
        <h2 class="h5 mb-3">Invite a user</h2>
        <% if current_user.email_delegations.empty? %>
          <p class="small text-muted">
            Connect a Gmail account on
            <%= link_to "your profile", profile_path %>
            so invitations can be sent. You can still create the invitation now — the email won't go out until you connect.
          </p>
        <% end %>
        <%= form_with model: @invitation, url: admin_tenant_invitations_path(@tenant), local: true do |f| %>
          <div class="input-group">
            <%= f.email_field :email, class: "form-control", placeholder: "name@example.com", required: true %>
            <%= f.submit "Send invite", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-header"><h3 class="h6 mb-0">Pending invitations</h3></div>
      <div class="card-body p-0">
        <% if @pending_invitations.any? %>
          <ul class="list-group list-group-flush mb-0">
            <% @pending_invitations.each do |inv| %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                  <div class="fw-semibold"><%= inv.email %></div>
                  <div class="small text-muted">Sent <%= time_ago_in_words(inv.created_at) %> ago · expires <%= time_ago_in_words(inv.expires_at) %> from now</div>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="p-3 text-center text-muted small">No pending invitations.</div>
        <% end %>
      </div>
    </div>
  </div>
</div>
