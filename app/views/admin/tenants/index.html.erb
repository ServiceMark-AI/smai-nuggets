<% content_for :title, "Tenants" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0">Tenants</h1>
  <%= link_to "New tenant", new_admin_tenant_path, class: "btn btn-primary btn-sm" %>
</div>

<div class="card shadow-sm">
  <div class="card-body p-0">
    <% if @tenants.any? %>
      <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th>Name</th>
            <th class="text-end">Locations</th>
            <th class="text-end">Users</th>
          </tr>
        </thead>
        <tbody>
          <% @tenants.each do |tenant| %>
            <tr>
              <td><%= link_to tenant.name, admin_tenant_path(tenant) %></td>
              <td class="text-end"><%= tenant.locations.count %></td>
              <td class="text-end"><%= tenant.users.count %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-4 text-center text-muted">No tenants.</div>
    <% end %>
  </div>
</div>
