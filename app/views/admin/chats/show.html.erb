<% content_for :title, "Chat ##{@chat.id}" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0">Chat #<%= @chat.id %></h1>
  <%= link_to "All chats", admin_chats_path, class: "btn btn-sm btn-outline-secondary" %>
</div>

<dl class="row mb-4">
  <dt class="col-sm-2">Model</dt>
  <dd class="col-sm-10"><%= @chat.model&.name || "—" %></dd>
  <dt class="col-sm-2">Created</dt>
  <dd class="col-sm-10"><%= l(@chat.created_at, format: :long) %></dd>
</dl>

<h2 class="h5 mb-2">Messages</h2>
<% if @messages.any? %>
  <% @messages.each do |m| %>
    <div class="card shadow-sm mb-2">
      <div class="card-body py-2 px-3">
        <div class="d-flex justify-content-between align-items-center mb-1">
          <span class="fw-semibold text-uppercase small text-muted"><%= m.role %></span>
          <span class="text-muted small">
            <% if m.input_tokens || m.output_tokens %>
              in: <%= m.input_tokens || 0 %> · out: <%= m.output_tokens || 0 %> ·
            <% end %>
            <%= l(m.created_at, format: :short) %>
          </span>
        </div>
        <div style="white-space: pre-wrap;"><%= m.content %></div>
      </div>
    </div>
  <% end %>
<% else %>
  <p class="text-muted">No messages.</p>
<% end %>
