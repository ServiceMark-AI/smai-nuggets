<%# Shared metrics body for both the admin (cross-tenant) and tenant
    Analytics views. Pass `analytics:` — an AnalyticsCalculator result.
    The wrapping show.html.erb supplies the page title, scope-label
    subtitle, and the pending-data callout so the two views can read
    differently above and below this partial. %>

<%# --- Hero tiles ----------------------------------------------------- %>
<div class="row g-3 mb-4">
  <div class="col-md">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <div class="text-muted text-uppercase small mb-1">Conversion rate</div>
        <div class="display-6 fw-semibold mb-1">
          <%= analytics.conversion_rate_pct.nil? ? "—" : "#{analytics.conversion_rate_pct}%" %>
        </div>
        <%# SPEC-05 v1.0: MTD / YTD dual display inside the Conversion Rate tile. %>
        <div class="d-flex gap-3 small mt-2 mb-2">
          <div>
            <span class="text-muted">MTD</span>
            <span class="fw-semibold ms-1">
              <%= analytics.conversion_rate_mtd_pct.nil? ? "—" : "#{analytics.conversion_rate_mtd_pct}%" %>
            </span>
          </div>
          <div>
            <span class="text-muted">YTD</span>
            <span class="fw-semibold ms-1">
              <%= analytics.conversion_rate_ytd_pct.nil? ? "—" : "#{analytics.conversion_rate_ytd_pct}%" %>
            </span>
          </div>
        </div>
        <div class="small text-muted">Won jobs as a % of activated proposals</div>

        <%# SPEC-06 v1.0: by-location breakdown.
            Visible only to tenant admins / SMAI staff (operators scoped to
            a single location see their own number above and don't need a
            "by location" expansion). Hidden when the scope has 0 or 1
            locations because there's nothing to compare. %>
        <% if !current_user.scoped_to_location? && analytics.conversion_rate_by_location.size > 1 %>
          <button class="btn btn-sm btn-link p-0 mt-2" type="button"
                  data-bs-toggle="collapse" data-bs-target="#cr-by-location"
                  aria-expanded="false" aria-controls="cr-by-location">
            By location ›
          </button>
          <div class="collapse mt-2" id="cr-by-location">
            <%# SPEC-06 §8.2 — one row per active location: name, rate as a
                whole-number %, proportional bar. Sort descending by rate
                with NULL (zero-denominator) rows last; ties broken
                alphabetically by display name. The top performer's bar
                fills the available width; others scale proportionally,
                same convention as the Originator Performance close-rate
                bars below. Zero-denominator rows render "—" with no bar. %>
            <%
              by_location = analytics.conversion_rate_by_location.sort_by { |r|
                [r[:conversion_rate_pct].nil? ? 1 : 0,
                 -(r[:conversion_rate_pct] || 0),
                 r[:location_display_name].to_s.downcase]
              }
              top_rate = by_location.map { |r| r[:conversion_rate_pct] || 0 }.max.to_i
            %>
            <table class="table table-sm mb-0 small align-middle">
              <tbody>
                <% by_location.each do |row| %>
                  <tr>
                    <td><%= row[:location_display_name] %></td>
                    <td class="text-end fw-semibold" style="width: 56px;">
                      <%= row[:conversion_rate_pct].nil? ? "—" : "#{row[:conversion_rate_pct]}%" %>
                    </td>
                    <td>
                      <% if row[:conversion_rate_pct] %>
                        <% width = top_rate.positive? ? (row[:conversion_rate_pct].to_f / top_rate * 100).round : 0 %>
                        <div class="progress" style="height: 8px;">
                          <div class="progress-bar bg-primary"
                               style="width: <%= width %>%; opacity: <%= [0.6, width / 100.0].max.round(2) %>;"
                               role="progressbar"
                               aria-valuenow="<%= row[:conversion_rate_pct] %>"
                               aria-valuemin="0" aria-valuemax="<%= top_rate %>"></div>
                        </div>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <div class="text-muted text-uppercase small mb-1">Closed revenue</div>
        <div class="h4 fw-semibold mb-1"><%= number_to_currency(analytics.closed_revenue, precision: 0) %></div>
        <%# MTD / YTD inline, mirroring the Conversion Rate tile pattern. %>
        <div class="d-flex gap-3 small mt-2 mb-2">
          <div>
            <span class="text-muted">MTD</span>
            <span class="fw-semibold ms-1">
              <%= number_to_currency(analytics.closed_revenue_mtd, precision: 0) %>
            </span>
          </div>
          <div>
            <span class="text-muted">YTD</span>
            <span class="fw-semibold ms-1">
              <%= number_to_currency(analytics.closed_revenue_ytd, precision: 0) %>
            </span>
          </div>
        </div>
        <div class="small text-muted">Proposal value of won jobs</div>
      </div>
    </div>
  </div>

  <div class="col-md">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <div class="text-muted text-uppercase small mb-1">Active pipeline</div>
        <div class="h4 fw-semibold mb-1"><%= number_to_currency(analytics.active_pipeline_value, precision: 0) %></div>
        <div class="small text-muted">Jobs currently in campaign</div>
      </div>
    </div>
  </div>

  <div class="col-md">
    <div class="card shadow-sm h-100">
      <div class="card-body opacity-50">
        <div class="text-muted text-uppercase small mb-1">Avg time to first reply</div>
        <div class="h4 fw-semibold mb-1">—</div>
        <div class="small text-muted">Hours from send to first customer reply, won jobs · <em>pending inbound-message tracking</em></div>
      </div>
    </div>
  </div>

  <div class="col-md">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <div class="text-muted text-uppercase small mb-1">Follow-ups sent</div>
        <div class="h4 fw-semibold mb-1"><%= number_with_delimiter(analytics.follow_ups_sent) %></div>
        <div class="small text-muted">Campaign-step emails marked sent</div>
      </div>
    </div>
  </div>
</div>

<%# --- Conversion rate by location ------------------------------------ %>
<%# Hidden for operators scoped to a single location and for tenants with
    only one location — the per-location grid has nothing to compare in
    those cases. %>
<% if !current_user.scoped_to_location? && analytics.conversion_rate_by_location.size > 1 %>
  <div class="card shadow-sm mb-4">
    <div class="card-header">
      <h2 class="h5 mb-0">Conversion rate by location</h2>
    </div>
    <div class="card-body">
      <div class="row g-3">
        <% analytics.conversion_rate_by_location.each do |loc| %>
          <div class="col-sm-6 col-md-4 col-lg-3">
            <div class="card h-100 border">
              <div class="card-body">
                <div class="text-muted text-uppercase small mb-1"><%= loc[:location_display_name] %></div>
                <div class="display-6 fw-semibold mb-1">
                  <%= loc[:conversion_rate_pct].nil? ? "—" : "#{loc[:conversion_rate_pct]}%" %>
                </div>
                <div class="d-flex gap-3 small mt-2">
                  <div>
                    <span class="text-muted">MTD</span>
                    <span class="fw-semibold ms-1">
                      <%= loc[:conversion_rate_mtd_pct].nil? ? "—" : "#{loc[:conversion_rate_mtd_pct]}%" %>
                    </span>
                  </div>
                  <div>
                    <span class="text-muted">YTD</span>
                    <span class="fw-semibold ms-1">
                      <%= loc[:conversion_rate_ytd_pct].nil? ? "—" : "#{loc[:conversion_rate_ytd_pct]}%" %>
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<%# --- Funnel --------------------------------------------------------- %>
<div class="card shadow-sm mb-4">
  <div class="card-header"><h2 class="h5 mb-0">Where jobs are won and lost</h2></div>
  <div class="card-body">
    <% funnel = [
         { label: "Proposals activated",       count: analytics.activated_count,          implemented: true },
         { label: "First follow-up delivered", count: analytics.first_followup_delivered, implemented: true },
         { label: "Customer replied",          count: analytics.customer_replied_count,   implemented: true },
         { label: "Operator responded",        count: nil,                                implemented: false },
         { label: "Closed won",                count: analytics.won_count,                implemented: true }
       ] %>
    <% funnel.each do |stage| %>
      <div class="d-flex align-items-center mb-2">
        <div class="me-3" style="width: 200px;">
          <div class="fw-semibold"><%= stage[:label] %></div>
          <div class="small text-muted">
            <% if stage[:implemented] %>
              <%= pluralize(stage[:count], "job") %>
            <% else %>
              <em>pending data</em>
            <% end %>
          </div>
        </div>
        <div class="flex-grow-1">
          <% if stage[:implemented] %>
            <% width_pct = (stage[:count].to_f / analytics.funnel_max * 100).clamp(2, 100).round %>
            <div class="progress" style="height: 32px;">
              <div class="progress-bar bg-primary" role="progressbar"
                   style="width: <%= width_pct %>%;"
                   aria-valuenow="<%= stage[:count] %>"
                   aria-valuemin="0"
                   aria-valuemax="<%= analytics.funnel_max %>">
                <%= stage[:count] %>
              </div>
            </div>
          <% else %>
            <div class="progress" style="height: 32px;">
              <div class="progress-bar bg-secondary" style="width: 100%; opacity: 0.15;">&nbsp;</div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
    <div class="small text-muted mt-3">
      Lost jobs (not part of the funnel above): <%= analytics.lost_count %>
    </div>
  </div>
</div>

<%# --- Originator performance ---------------------------------------- %>
<div class="card shadow-sm mb-4">
  <div class="card-header"><h2 class="h5 mb-0">Originator performance</h2></div>
  <div class="card-body p-0">
    <% if analytics.originators.any? %>
      <table class="table mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th>Originator</th>
            <th class="text-end">Active jobs</th>
            <th class="text-end">Pipeline</th>
            <th class="text-end">Reply rate</th>
            <th>Close rate</th>
          </tr>
        </thead>
        <tbody>
          <% top_close = analytics.originators.first[:close_rate_pct] %>
          <% analytics.originators.each do |row| %>
            <tr>
              <td>
                <%= row[:user].display_name %>
                <% if (loc = row[:user].location) %>
                  <div class="text-muted small"><%= loc.display_name %></div>
                <% end %>
              </td>
              <td class="text-end"><%= row[:active_jobs] %></td>
              <td class="text-end"><%= number_to_currency(row[:pipeline_value], precision: 0) %></td>
              <td class="text-end">
                <% if row[:reply_rate_pct].nil? %>
                  <span class="text-muted">—</span>
                <% else %>
                  <%= row[:reply_rate_pct] %>%
                  <div class="text-muted small"><%= row[:replied_count] %>/<%= row[:activated_count] %></div>
                <% end %>
              </td>
              <td>
                <% width = top_close.positive? ? (row[:close_rate_pct].to_f / top_close * 100).round : 0 %>
                <div class="d-flex align-items-center gap-2">
                  <div class="progress flex-grow-1" style="height: 8px;">
                    <div class="progress-bar bg-primary" style="width: <%= width %>%; opacity: <%= [0.6, width / 100.0].max.round(2) %>;"></div>
                  </div>
                  <span class="small fw-semibold" style="width: 36px;"><%= row[:close_rate_pct] %>%</span>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-4 text-center text-muted">No originator data yet — no proposals owned.</div>
    <% end %>
  </div>
</div>

<%# --- Activity chart ------------------------------------------------- %>
<div class="card shadow-sm mb-4">
  <div class="card-header"><h2 class="h5 mb-0">Follow-up activity (last 30 days)</h2></div>
  <div class="card-body">
    <% if analytics.follow_ups_by_day.any? %>
      <% peak = analytics.follow_ups_by_day.values.max %>
      <div class="d-flex align-items-end gap-1" style="height: 120px;">
        <% (29.days.ago.to_date..Date.current).each do |d| %>
          <% n = analytics.follow_ups_by_day[d] || analytics.follow_ups_by_day[d.to_s] || 0 %>
          <% h = peak.positive? ? (n.to_f / peak * 100).round : 0 %>
          <div class="flex-grow-1 d-flex flex-column align-items-center justify-content-end"
               title="<%= d.strftime("%b %-d") %>: <%= n %> sent">
            <div class="w-100 bg-primary" style="height: <%= [h, 2].max %>%; opacity: <%= n.positive? ? 1 : 0.1 %>;"></div>
          </div>
        <% end %>
      </div>
      <div class="d-flex justify-content-between small text-muted mt-2">
        <span><%= 29.days.ago.to_date.strftime("%b %-d") %></span>
        <span>Today</span>
      </div>
    <% else %>
      <div class="text-muted">No campaign emails recorded in the last 30 days.</div>
    <% end %>
  </div>
</div>

<%# --- Loss reasons --------------------------------------------------- %>
<div class="card shadow-sm mb-4">
  <div class="card-header"><h2 class="h5 mb-0">Why we lost</h2></div>
  <div class="card-body">
    <% if analytics.loss_reasons_breakdown.any? %>
      <%# Six product reasons + an "Unspecified" fallback — pick a palette
          big enough to cover all of them with distinct hues. %>
      <% palette = %w[#0d6efd #198754 #ffc107 #0dcaf0 #dc3545 #6610f2 #6c757d] %>
      <% total = analytics.loss_reasons_breakdown.sum { |r| r[:count] } %>
      <%
        cursor = 0.0
        slices = analytics.loss_reasons_breakdown.each_with_index.map do |row, i|
          start_pct = (cursor * 100).round(2)
          fraction  = total.positive? ? row[:count].to_f / total : 0.0
          cursor   += fraction
          end_pct   = (cursor * 100).round(2)
          {
            row:        row,
            color:      palette[i % palette.size],
            from_pct:   start_pct,
            to_pct:     end_pct,
            share_pct:  (fraction * 100).round
          }
        end
      %>
      <% gradient_stops = slices.map { |s| "#{s[:color]} #{s[:from_pct]}% #{s[:to_pct]}%" }.join(", ") %>

      <div class="d-flex flex-wrap align-items-center gap-4">
        <div class="rounded-circle flex-shrink-0"
             style="width: 180px; height: 180px; background: conic-gradient(<%= gradient_stops %>);"
             role="img"
             aria-label="Loss reasons breakdown">
        </div>

        <div class="flex-grow-1" style="min-width: 280px;">
          <table class="table table-sm mb-0 align-middle">
            <thead class="table-light">
              <tr>
                <th style="width: 24px;"></th>
                <th>Reason</th>
                <th class="text-end">Lost jobs</th>
                <th class="text-end">Share</th>
              </tr>
            </thead>
            <tbody>
              <% slices.each do |s| %>
                <tr>
                  <td>
                    <span class="d-inline-block rounded"
                          style="width: 14px; height: 14px; background: <%= s[:color] %>;"></span>
                  </td>
                  <td><%= s[:row][:display_name] %></td>
                  <td class="text-end"><%= s[:row][:count] %></td>
                  <td class="text-end"><%= s[:share_pct] %>%</td>
                </tr>
              <% end %>
            </tbody>
            <tfoot>
              <tr class="text-muted small">
                <td></td>
                <td>Total</td>
                <td class="text-end"><%= total %></td>
                <td class="text-end">100%</td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    <% else %>
      <div class="text-muted">No lost jobs yet — nothing to break down.</div>
    <% end %>
  </div>
</div>
