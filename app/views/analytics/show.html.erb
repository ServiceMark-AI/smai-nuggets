<% content_for :title, "Analytics" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h1 class="h3 mb-1">Analytics</h1>
    <div class="text-muted small">
      <% if current_user.tenant %>
        All-time scope, <%= current_user.tenant.name %> · <%= pluralize(@analytics.total_proposals, "proposal") %>.
      <% else %>
        No tenant assigned to your account — analytics are empty until you're invited into one.
      <% end %>
      Per PRD-07 §6, a date / location / job-type filter bar lives here once those scopes are wired.
    </div>
  </div>
</div>

<%= render "analytics/dashboard", analytics: @analytics %>
