<% content_for :title, "Analytics" %>

<div class="d-flex justify-content-between align-items-end mb-3 gap-3 flex-wrap">
  <div>
    <h1 class="h3 mb-1">Analytics</h1>
    <div class="text-muted small">
      <% if current_user.tenant %>
        <%
          scope_label = if @selected_location_id
                          loc = @location_options.find { |l| l.id == @selected_location_id.to_i }
                          "#{current_user.tenant.name} · #{loc&.display_name}"
                        else
                          current_user.tenant.name
                        end
        %>
        All-time scope, <%= scope_label %> · <%= pluralize(@analytics.total_proposals, "proposal") %>.
      <% else %>
        No tenant assigned to your account — analytics are empty until you're invited into one.
      <% end %>
    </div>
  </div>

  <%# Location slicer — admins / tenant admins only. Originators are
      forced to their own location server-side and don't see the picker
      (it would only have one option anyway). Hidden when the tenant
      has zero or one locations. %>
  <% if !current_user.scoped_to_location? && @location_options.size > 1 %>
    <%= form_with url: analytics_path, method: :get, local: true, class: "d-flex align-items-end gap-2" do |f| %>
      <div>
        <%= label_tag :location_id, "Location", class: "form-label small mb-1" %>
        <%= select_tag :location_id,
              options_from_collection_for_select(@location_options, :id, :display_name, @selected_location_id),
              include_blank: "All locations",
              class: "form-select form-select-sm",
              onchange: "this.form.submit()" %>
      </div>
    <% end %>
  <% end %>
</div>

<%= render "analytics/dashboard", analytics: @analytics %>
