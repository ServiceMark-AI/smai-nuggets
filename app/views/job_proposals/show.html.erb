<% content_for :title, @job_proposal.short_address || "Job Proposal" %>

<%= link_to "← Back to Job Proposals", job_proposals_path, class: "small text-muted" %>

<div class="d-flex align-items-center gap-3 mt-2 mb-4">
  <h1 class="h3 mb-0">
    <%= @job_proposal.short_address || "Job Proposal ##{@job_proposal.id}" %>
  </h1>
  <%# Same CTA function the index uses. Suppress view_job here since
      the operator is literally viewing the job — the alternatives
      (Open in Gmail, Fix delivery issue, Resume campaign) are still
      actionable. %>
  <% if @job_proposal.cta != :view_job %>
    <%= job_proposal_cta_link(@job_proposal) %>
  <% end %>
  <% if %w[won lost].include?(@job_proposal.pipeline_stage) %>
    <%= button_to "Revert to in campaign", revert_pipeline_stage_job_proposal_path(@job_proposal),
          method: :patch,
          class: "btn btn-outline-secondary btn-sm",
          form: { class: "d-inline" },
          title: "Undo an accidental Mark Won / Mark Lost." %>
  <% else %>
    <%= button_to "Mark Won", mark_won_job_proposal_path(@job_proposal),
          method: :patch,
          class: "btn btn-outline-success btn-sm",
          form: { class: "d-inline" } %>
    <%= button_to "Mark Lost", mark_lost_job_proposal_path(@job_proposal),
          method: :patch,
          class: "btn btn-outline-danger btn-sm",
          form: { class: "d-inline" } %>
    <%# Pause only makes sense while a CampaignInstance is actively
        running. A completed run (all steps shipped) or a terminal-stopped
        run (delivery_issue, customer_reply, etc.) has nothing to pause. %>
    <% latest_instance = @job_proposal.campaign_instances.order(created_at: :desc).first %>
    <% if latest_instance&.status_active? %>
      <%= button_to "Pause", pause_job_proposal_path(@job_proposal),
            method: :patch,
            class: "btn btn-outline-warning btn-sm",
            form: { class: "d-inline" } %>
    <% end %>
  <% end %>
</div>

<% attachments = @job_proposal.attachments.select { |a| a.file.attached? } %>

<div class="card shadow-sm mb-4">
  <div class="card-header">
    <h2 class="h5 mb-0">Customer</h2>
  </div>
  <div class="card-body">
    <dl class="row mb-0">
      <dt class="col-sm-3">Name</dt>
      <dd class="col-sm-9">
        <%= [@job_proposal.customer_first_name, @job_proposal.customer_last_name].compact_blank.join(" ").presence || content_tag(:span, "—", class: "text-muted") %>
      </dd>

      <dt class="col-sm-3">Address</dt>
      <dd class="col-sm-9">
        <% if @job_proposal.short_address %>
          <%= @job_proposal.short_address %><br>
          <%= [@job_proposal.customer_city, @job_proposal.customer_state, @job_proposal.customer_zip].compact_blank.join(", ") %>
        <% else %>
          <span class="text-muted">—</span>
        <% end %>
      </dd>
    </dl>
  </div>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-header">
    <h2 class="h5 mb-0">Job</h2>
  </div>
  <div class="card-body">
    <dl class="row mb-0">
      <dt class="col-sm-3">Job type</dt>
      <dd class="col-sm-9"><%= @job_proposal.job_type&.name || content_tag(:span, "—", class: "text-muted") %></dd>

      <dt class="col-sm-3">Scenario</dt>
      <dd class="col-sm-9"><%= @job_proposal.scenario&.short_name || content_tag(:span, "—", class: "text-muted") %></dd>

      <dt class="col-sm-3">Status</dt>
      <dd class="col-sm-9"><span class="badge text-bg-secondary"><%= @job_proposal.status %></span></dd>

      <dt class="col-sm-3">Status overlay</dt>
      <dd class="col-sm-9">
        <% if @job_proposal.status_overlay %>
          <% ov_class = case @job_proposal.status_overlay when "delivery_issue", "customer_waiting" then "text-bg-danger" when "paused" then "text-bg-warning" else "text-bg-info" end %>
          <span class="badge <%= ov_class %>"><%= @job_proposal.status_overlay.humanize %></span>
        <% else %>
          <span class="text-muted small fst-italic">No overlay</span>
        <% end %>
      </dd>

      <dt class="col-sm-3">Pipeline stage</dt>
      <dd class="col-sm-9">
        <% if @job_proposal.pipeline_stage %>
          <% pipe_class = case @job_proposal.pipeline_stage when "won" then "badge text-bg-success" when "lost" then "badge border border-danger text-danger" else "badge text-bg-info" end %>
          <span class="<%= pipe_class %>"><%= @job_proposal.pipeline_stage.humanize %></span>
        <% else %>
          <span class="text-muted small fst-italic">No pipeline stage</span>
        <% end %>
      </dd>

      <dt class="col-sm-3">Proposal value</dt>
      <dd class="col-sm-9">
        <% if @job_proposal.proposal_value %>
          <%= number_to_currency(@job_proposal.proposal_value) %>
        <% else %>
          <span class="text-muted">—</span>
        <% end %>
      </dd>

      <dt class="col-sm-3">Description</dt>
      <dd class="col-sm-9">
        <%= simple_format(@job_proposal.job_description.presence || content_tag(:span, "—", class: "text-muted").to_s) %>
      </dd>
    </dl>
  </div>
</div>

<% campaign_instance = @job_proposal.campaign_instances.order(created_at: :desc).first %>
<div class="card shadow-sm mb-4">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h2 class="h5 mb-0">Campaign</h2>
    <% if campaign_instance %>
      <% inst_status_class = case campaign_instance.status
         when "active"    then "text-bg-success"
         when "paused"    then "text-bg-warning"
         when "completed" then "text-bg-secondary"
         else "text-bg-danger" # stopped_on_*
         end %>
      <span class="badge <%= inst_status_class %>"><%= campaign_instance.status.humanize %></span>
    <% else %>
      <span class="badge text-bg-secondary">Not started</span>
    <% end %>
  </div>
<% if campaign_instance %>
    <div class="card-body p-0">
      <dl class="row mb-0 px-3 pt-3">
        <dt class="col-sm-3">Campaign</dt>
        <dd class="col-sm-9"><%= link_to campaign_instance.campaign.name, job_proposal_campaign_instance_path(@job_proposal, campaign_instance) %></dd>
      </dl>

      <% step_instances = campaign_instance.step_instances
                          .includes(:campaign_step)
                          .joins(:campaign_step)
                          .order("campaign_steps.sequence_number") %>
      <table class="table mb-0 align-middle small mt-2">
        <thead class="table-light">
          <tr>
            <th style="width: 48px;">#</th>
            <th>Step</th>
            <th style="width: 130px;">Status</th>
            <th style="width: 240px;">When</th>
            <th style="width: 110px;">Thread</th>
          </tr>
        </thead>
        <tbody>
          <% step_instances.each do |si| %>
            <% step_status = si.email_delivery_status
               status_class = case step_status
                 when "sent"    then "text-bg-success"
                 when "sending" then "text-bg-info"
                 when "pending" then "text-bg-secondary"
                 when "failed", "bounced" then "text-bg-danger"
                 else "text-bg-secondary"
                 end
               # For sent steps the recorded final_subject is what shipped;
               # otherwise render the live template against this proposal's
               # data so the inline subject reflects what would go out now.
               displayed_subject = if step_status == "sent" && si.final_subject.present?
                                    si.final_subject
                                  else
                                    MailGenerator.render_safely(campaign_step: si.campaign_step, job_proposal: @job_proposal).subject
                                  end %>
            <tr>
              <td><%= si.campaign_step.sequence_number %></td>
              <td>
                <%= link_to job_proposal_step_instance_path(@job_proposal, si), class: "text-decoration-none" do %>
                  <%= displayed_subject.presence || content_tag(:span, "(no subject)", class: "text-muted fst-italic") %>
                <% end %>
              </td>
              <td><span class="badge <%= status_class %>"><%= step_status.humanize %></span></td>
              <td>
                <% if step_status == "sent" %>
                  Sent <%= time_ago_in_words(si.updated_at) %> ago
                <% elsif step_status == "pending" && si.planned_delivery_at %>
                  <% if si.planned_delivery_at > Time.current %>
                    Scheduled in <%= time_ago_in_words(si.planned_delivery_at) %>
                  <% else %>
                    <span class="text-warning">Due now (next sweep)</span>
                  <% end %>
                <% elsif %w[failed bounced].include?(step_status) %>
                  Failed <%= time_ago_in_words(si.updated_at) %> ago
                <% else %>
                  <span class="text-muted">—</span>
                <% end %>
              </td>
              <td>
                <% if si.gmail_thread_id.present? %>
                  <%= link_to "Open ↗", gmail_thread_url(si.gmail_thread_id),
                        target: "_blank", rel: "noopener", class: "small" %>
                <% else %>
                  <span class="text-muted">—</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="card-body">
      <% blockers = @job_proposal.campaign_readiness_blockers %>
      <% if blockers.any? %>
        <p class="mb-2">No campaign has launched for this proposal — required fields are still blank:</p>
        <ul class="mb-3">
          <% blockers.each do |b| %>
            <li><strong><%= b[:field].to_s.humanize %></strong> — <%= b[:reason] %></li>
          <% end %>
        </ul>
        <%= link_to "Edit proposal", edit_job_proposal_path(@job_proposal), class: "btn btn-sm btn-primary" %>
      <% elsif @job_proposal.scenario.campaign.nil? %>
        <p class="mb-0">
          The <strong><%= @job_proposal.scenario.short_name %></strong> scenario has no campaign attached yet, so there's nothing to launch.
          <% if current_user.is_admin %>
            Go to the
            <%= link_to "scenario", admin_scenario_path(@job_proposal.scenario) %>
            and pick a campaign from the dropdown.
          <% else %>
            Ask an admin to attach one.
          <% end %>
        </p>
      <% else %>
        <p class="mb-2">
          No campaign instance has launched yet — usually this means the launch step was skipped (an automation hiccup, or the proposal was saved before the scenario was picked). The data is in place now; you can kick it off manually.
        </p>
        <%= button_to "Launch campaign", launch_campaign_job_proposal_path(@job_proposal),
              method: :post, class: "btn btn-sm btn-primary",
              form: { class: "m-0" } %>
      <% end %>
    </div>
  <% end %>
</div>

<div class="card shadow-sm">
  <div class="card-header">
    <h2 class="h5 mb-0">Ownership</h2>
  </div>
  <div class="card-body">
    <dl class="row mb-0">
      <dt class="col-sm-3">Organization</dt>
      <dd class="col-sm-9"><%= @job_proposal.organization.name %></dd>

      <dt class="col-sm-3">Owner</dt>
      <dd class="col-sm-9"><%= @job_proposal.owner.display_name %></dd>

      <dt class="col-sm-3">Created by</dt>
      <dd class="col-sm-9"><%= @job_proposal.created_by_user.display_name %></dd>

      <dt class="col-sm-3">Created at</dt>
      <dd class="col-sm-9"><%= @job_proposal.created_at.to_fs(:long) %></dd>
    </dl>
  </div>
</div>

<% if attachments.any? %>
  <div class="card shadow-sm mt-4">
    <div class="card-header">
      <h2 class="h5 mb-0">Uploaded file<%= "s" if attachments.size > 1 %></h2>
    </div>
    <div class="card-body">
      <ul class="list-unstyled mb-0">
        <% attachments.each do |att| %>
          <% source = attachment_storage_source(att.file) %>
          <% is_pdf = att.file.content_type == "application/pdf" || att.file.filename.to_s.downcase.end_with?(".pdf") %>
          <li class="<%= 'mt-2' unless att == attachments.first %>">
            <%= link_to att.file.filename.to_s, rails_blob_path(att.file, disposition: "inline"), target: "_blank", rel: "noopener" %>
            <% if is_pdf %>
              <span class="badge text-bg-info ms-2">Attached to first email</span>
            <% end %>
            <span class="text-muted small ms-2">
              uploaded <%= time_ago_in_words(att.created_at) %> ago<% if att.uploaded_by_user %> by <%= att.uploaded_by_user.display_name %><% end %>
            </span>
            <div class="text-muted small">
              Stored in <strong><%= source[:service] %></strong><% if source[:location] %> · <%= source[:location] %><% end %>
              <span class="ms-2">key <code><%= source[:key] %></code></span>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
<% end %>
