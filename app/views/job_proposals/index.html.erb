<% content_for :title, "Jobs" %>

<div class="d-flex align-items-center gap-3 mb-3">
  <div class="d-flex align-items-baseline gap-2">
    <h1 class="h3 mb-0">Jobs</h1>
    <% if current_user.scoped_to_location? && current_user.location %>
      <span class="text-muted small">at <%= current_user.location.display_name %></span>
    <% end %>
  </div>
  <div class="ms-auto d-flex gap-2">
    <%= link_to "New Job", new_job_proposal_path, class: "btn btn-primary btn-sm" %>
    <% if current_user.is_admin %>
      <%= link_to "New Manual Job", new_admin_job_proposal_path, class: "btn btn-outline-primary btn-sm" %>
    <% end %>
  </div>
</div>

<%= form_with url: job_proposals_path, method: :get, local: true, class: "card shadow-sm mb-3" do |f| %>
  <div class="card-body py-3">
    <div class="row g-2 align-items-end">
      <div class="col-sm-4">
        <%= label_tag :q, "Search", class: "form-label small mb-1" %>
        <%= text_field_tag :q, @search,
              placeholder: "Customer, address, or reference",
              class: "form-control form-control-sm" %>
      </div>
      <% if @show_location_controls %>
        <div class="col-sm-2">
          <%= label_tag :location_id, "Location", class: "form-label small mb-1" %>
          <%= select_tag :location_id,
                options_from_collection_for_select(@location_options, :id, :display_name, @selected_location_id),
                include_blank: "All locations",
                class: "form-select form-select-sm" %>
        </div>
      <% end %>
      <div class="col-sm-2">
        <%= label_tag :status, "Status", class: "form-label small mb-1" %>
        <%= select_tag :status,
              options_for_select(@status_options.map { |s| [s.humanize, s] }, @selected_status),
              include_blank: "All statuses",
              class: "form-select form-select-sm" %>
      </div>
      <div class="col-sm-2">
        <%= label_tag :owner_id, "Owner", class: "form-label small mb-1" %>
        <%= select_tag :owner_id,
              options_from_collection_for_select(@user_options, :id, :display_name, @selected_owner_id),
              include_blank: "Any owner",
              class: "form-select form-select-sm" %>
      </div>
      <div class="col-sm-2">
        <%= label_tag :creator_id, "Created by", class: "form-label small mb-1" %>
        <%= select_tag :creator_id,
              options_from_collection_for_select(@user_options, :id, :display_name, @selected_creator_id),
              include_blank: "Any creator",
              class: "form-select form-select-sm" %>
      </div>
      <% # Preserve the active sort across filter submits %>
      <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
      <%= hidden_field_tag :dir,  params[:dir]  if params[:dir].present?  %>
      <div class="col-sm-2 d-flex gap-2">
        <%= f.submit "Filter", class: "btn btn-primary btn-sm" %>
        <% if @selected_status || @selected_owner_id || @selected_creator_id || @selected_location_id || @search.present? %>
          <%= link_to "Clear", job_proposals_path, class: "btn btn-outline-secondary btn-sm" %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<div class="card shadow-sm">
  <div class="card-body p-0">
    <% if @job_proposals.any? %>
      <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <% if @show_location_controls %>
              <th>Location</th>
            <% end %>
            <th>Address</th>
            <th>CTA</th>
            <th>Customer</th>
            <th>Status overlay<br>Pipeline stage</th>
            <th>Job Type</th>
            <th>Status</th>
            <%= sortable_header "proposal_value", "Proposal value", th_class: "text-end" %>
            <th>Owner</th>
            <%= sortable_header "created_at", "Created" %>
          </tr>
        </thead>
        <tbody>
          <% @job_proposals.each do |jp| %>
            <tr>
              <% if @show_location_controls %>
                <td>
                  <% if jp.location %>
                    <%= jp.location.display_name %>
                  <% else %>
                    <span class="text-muted">—</span>
                  <% end %>
                </td>
              <% end %>
              <td>
                <% if jp.short_address %>
                  <%= link_to jp.short_address, job_proposal_path(jp) %>
                <% else %>
                  <%= link_to "—", job_proposal_path(jp), class: "text-muted" %>
                <% end %>
              </td>
              <td><%= job_proposal_cta_link(jp) %></td>
              <td><%= [jp.customer_first_name, jp.customer_last_name].compact_blank.join(" ").presence || "—" %></td>
              <td>
                <% if jp.status_overlay %>
                  <% ov_class = case jp.status_overlay when "delivery_issue", "customer_waiting" then "text-bg-danger" when "paused" then "text-bg-warning" else "text-bg-info" end %>
                  <span class="badge <%= ov_class %>"><%= jp.status_overlay.humanize %></span>
                <% else %>
                  <span class="text-muted small fst-italic">No overlay</span>
                <% end %>
                <div class="mt-1">
                  <% if jp.pipeline_stage %>
                    <% pipe_class = case jp.pipeline_stage when "won" then "badge text-bg-success" when "lost" then "badge border border-danger text-danger" else "badge text-bg-info" end %>
                    <span class="<%= pipe_class %>"><%= jp.pipeline_stage.humanize %></span>
                  <% else %>
                    <span class="text-muted small fst-italic">No pipeline stage</span>
                  <% end %>
                </div>
              </td>
              <td><%= jp.job_type&.name || "—" %></td>
              <td><span class="badge text-bg-secondary"><%= jp.status %></span></td>
              <td class="text-end"><%= number_to_currency(jp.proposal_value) if jp.proposal_value %></td>
              <td><%= jp.owner.display_name %></td>
              <td>
                <%= jp.created_at.to_date.to_fs(:long) %>
                <% if jp.created_by_user %>
                  <div class="small text-muted">by <%= jp.created_by_user.display_name %></div>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-4 text-center text-muted">No job proposals match these filters.</div>
    <% end %>
  </div>
</div>
