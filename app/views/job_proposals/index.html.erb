<%
  page_title = @needs_attention_only ? "Jobs Requiring Attention" : "Jobs"
  count = @job_proposals.size
%>
<% content_for :title, page_title %>

<div class="d-flex align-items-center gap-3 mb-3">
  <div class="d-flex align-items-baseline gap-2">
    <h1 class="h3 mb-0"><%= page_title %></h1>
    <% if current_user.scoped_to_location? && current_user.location %>
      <span class="text-muted small">at <%= current_user.location.display_name %></span>
    <% end %>
  </div>
  <div class="ms-auto d-flex align-items-center gap-3">
    <span class="text-muted small"><%= pluralize(count, "item") %></span>
    <%= link_to "New Job", new_job_proposal_path, class: "btn btn-primary btn-sm" %>
    <% if current_user.is_admin %>
      <%= link_to "New Manual Job", new_admin_job_proposal_path, class: "btn btn-outline-primary btn-sm" %>
    <% end %>
  </div>
</div>

<%= form_with url: job_proposals_path, method: :get, local: true, class: "card shadow-sm mb-3" do |f| %>
  <div class="card-body py-3">
    <div class="row g-2 align-items-end">
      <div class="col-sm-4">
        <%= label_tag :q, "Search", class: "form-label small mb-1" %>
        <%= text_field_tag :q, @search,
              placeholder: "Customer, address, or reference",
              class: "form-control form-control-sm" %>
      </div>
      <% if @show_location_controls %>
        <div class="col-sm-2">
          <%= label_tag :location_id, "Location", class: "form-label small mb-1" %>
          <%= select_tag :location_id,
                options_from_collection_for_select(@location_options, :id, :display_name, @selected_location_id),
                include_blank: "All locations",
                class: "form-select form-select-sm" %>
        </div>
      <% end %>
      <div class="col-sm-2">
        <%= label_tag :status, "Status", class: "form-label small mb-1" %>
        <%= select_tag :status,
              options_for_select(@status_options.map { |s| [s.humanize, s] }, @selected_status),
              include_blank: "All statuses",
              class: "form-select form-select-sm" %>
      </div>
      <div class="col-sm-2">
        <%= label_tag :owner_id, "Owner", class: "form-label small mb-1" %>
        <%= select_tag :owner_id,
              options_from_collection_for_select(@user_options, :id, :display_name, @selected_owner_id),
              include_blank: "Any owner",
              class: "form-select form-select-sm" %>
      </div>
      <div class="col-sm-2">
        <%= label_tag :creator_id, "Created by", class: "form-label small mb-1" %>
        <%= select_tag :creator_id,
              options_from_collection_for_select(@user_options, :id, :display_name, @selected_creator_id),
              include_blank: "Any creator",
              class: "form-select form-select-sm" %>
      </div>
      <%= hidden_field_tag :filter, params[:filter] if params[:filter].present? %>
      <div class="col-sm-2 d-flex gap-2">
        <%= f.submit "Filter", class: "btn btn-primary btn-sm" %>
        <% if @selected_status || @selected_owner_id || @selected_creator_id || @selected_location_id || @search.present? %>
          <%= link_to "Clear", job_proposals_path(filter: params[:filter]), class: "btn btn-outline-secondary btn-sm" %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<% if @job_proposals.any? %>
  <% @job_proposals.each do |jp| %>
    <div class="card shadow-sm mb-2 jp-card">
      <div class="card-body d-flex align-items-center gap-3 p-3">
        <%= link_to job_proposal_path(jp), class: "flex-grow-1 text-decoration-none text-reset" do %>
          <div class="d-flex align-items-baseline flex-wrap gap-2 mb-1">
            <span class="fw-bold">
              <%= [jp.customer_first_name, jp.customer_last_name].compact_blank.join(" ").presence || "Job ##{jp.id}" %>
            </span>
            <% if jp.proposal_value %>
              <span class="text-muted fw-bold"><%= number_to_currency(jp.proposal_value, precision: 0) %></span>
            <% end %>
          </div>
          <div class="text-muted mb-1">
            <%= proposal_full_address(jp) || "—" %>
          </div>
          <div class="small">
            <% if @show_location_controls && jp.location %>
              <span class="text-muted me-2"><%= jp.location.display_name %></span>
              <span class="text-muted me-2">·</span>
            <% end %>
            <span class="text-muted me-2"><%= jp.job_type&.name || "no job type" %></span>
            <% if (overlay = proposal_overlay_label(jp)) %>
              <span class="text-muted me-2">·</span>
              <%= overlay %>
            <% end %>
          </div>
        <% end %>
        <div class="ms-auto flex-shrink-0"><%= job_proposal_cta_link(jp) %></div>
      </div>
    </div>
  <% end %>
<% else %>
  <div class="card shadow-sm">
    <div class="card-body p-4 text-center text-muted">No job proposals match these filters.</div>
  </div>
<% end %>
