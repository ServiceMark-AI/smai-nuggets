<% content_for :title, "Job Proposals" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0">Job Proposals</h1>
  <%= link_to "New job", new_job_proposal_path, class: "btn btn-primary btn-sm" %>
</div>

<%= form_with url: job_proposals_path, method: :get, local: true, class: "card shadow-sm mb-3" do |f| %>
  <div class="card-body py-3">
    <div class="row g-2 align-items-end">
      <div class="col-sm-4">
        <%= label_tag :q, "Search", class: "form-label small mb-1" %>
        <%= text_field_tag :q, @search,
              placeholder: "Customer, address, or reference",
              class: "form-control form-control-sm" %>
      </div>
      <div class="col-sm-2">
        <%= label_tag :status, "Status", class: "form-label small mb-1" %>
        <%= select_tag :status,
              options_for_select(@status_options.map { |s| [s.humanize, s] }, @selected_status),
              include_blank: "All statuses",
              class: "form-select form-select-sm" %>
      </div>
      <div class="col-sm-2">
        <%= label_tag :owner_id, "Owner", class: "form-label small mb-1" %>
        <%= select_tag :owner_id,
              options_from_collection_for_select(@user_options, :id, :display_name, @selected_owner_id),
              include_blank: "Any owner",
              class: "form-select form-select-sm" %>
      </div>
      <div class="col-sm-2">
        <%= label_tag :creator_id, "Created by", class: "form-label small mb-1" %>
        <%= select_tag :creator_id,
              options_from_collection_for_select(@user_options, :id, :display_name, @selected_creator_id),
              include_blank: "Any creator",
              class: "form-select form-select-sm" %>
      </div>
      <% # Preserve the active sort across filter submits %>
      <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
      <%= hidden_field_tag :dir,  params[:dir]  if params[:dir].present?  %>
      <div class="col-sm-2 d-flex gap-2">
        <%= f.submit "Filter", class: "btn btn-primary btn-sm" %>
        <% if @selected_status || @selected_owner_id || @selected_creator_id || @search.present? %>
          <%= link_to "Clear", job_proposals_path, class: "btn btn-outline-secondary btn-sm" %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<div class="card shadow-sm">
  <div class="card-body p-0">
    <% if @job_proposals.any? %>
      <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th>Address</th>
            <th>Customer</th>
            <th>Organization</th>
            <th>Job Type</th>
            <th>Status</th>
            <%= sortable_header "proposal_value", "Proposal value", th_class: "text-end" %>
            <th>Owner</th>
            <th>Created by</th>
            <%= sortable_header "created_at", "Created" %>
          </tr>
        </thead>
        <tbody>
          <% @job_proposals.each do |jp| %>
            <tr>
              <td>
                <% if jp.short_address %>
                  <%= link_to jp.short_address, job_proposal_path(jp) %>
                <% else %>
                  <%= link_to "—", job_proposal_path(jp), class: "text-muted" %>
                <% end %>
              </td>
              <td><%= [jp.customer_first_name, jp.customer_last_name].compact_blank.join(" ").presence || "—" %></td>
              <td><%= jp.organization.name %></td>
              <td><%= jp.job_type&.name || "—" %></td>
              <td><span class="badge text-bg-secondary"><%= jp.status %></span></td>
              <td class="text-end"><%= number_to_currency(jp.proposal_value) if jp.proposal_value %></td>
              <td><%= jp.owner.display_name %></td>
              <td><%= jp.created_by_user.display_name %></td>
              <td><%= jp.created_at.to_date.to_fs(:long) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-4 text-center text-muted">No job proposals match these filters.</div>
    <% end %>
  </div>
</div>
