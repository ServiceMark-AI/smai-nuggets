<%
  title   = "You're invited to #{@tenant.name} on ServiceMark AI"
  heading = "You're invited to #{@tenant.name}"

  intro = capture do %>
    <p style="margin: 0 0 16px 0; font-size: 15px; line-height: 1.6; color: #424a53;">
      <% if @from_admin %>
        A ServiceMark AI administrator has invited you to join <strong><%= @tenant.name %></strong>.
      <% else %>
        <strong><%= @inviter_name %></strong> has invited you to join <strong><%= @tenant.name %></strong> on ServiceMark AI.
      <% end %>
    </p>
    <p style="margin: 0 0 28px 0; font-size: 15px; line-height: 1.6; color: #424a53;">
      Accept the invitation to create your account and get started.
    </p>
  <% end

  footer = capture do %>
    <p style="margin: 0 0 8px 0; font-size: 13px; color: #6c757d; line-height: 1.5;">
      This link expires <%= @expires_at.to_fs(:long) %>.
    </p>
    <p style="margin: 0; font-size: 13px; color: #6c757d; line-height: 1.5;">
      If you don't have a ServiceMark AI account yet, you'll be asked to sign up — your tenant and organization will be set up automatically.
    </p>
  <% end %>

<%= render "shared/email_shell",
      title:     title,
      heading:   heading,
      intro:     intro,
      cta_label: "Accept invitation",
      cta_url:   @accept_url,
      footer:    footer,
      aside:     "You received this email because someone invited you to a ServiceMark AI account. If this wasn't expected, you can safely ignore it." %>
