<aside class="col-md-3 col-lg-2 bg-body-tertiary border-end py-4">
  <nav class="nav flex-column">
    <%= link_to "Job Proposals", job_proposals_path, class: "nav-link #{'active' if controller_name == 'job_proposals'}" %>
    <%= link_to "Users", users_path, class: "nav-link #{'active' if controller_name == 'users'}" %>

    <% if current_user.is_admin %>
      <h6 class="text-uppercase text-muted small mt-3 mb-1 px-3">Admin</h6>
      <%= link_to "Tenants", admin_tenants_path, class: "nav-link #{'active' if controller_name == 'tenants'}" %>
      <%= link_to "Job Types", admin_job_types_path, class: "nav-link #{'active' if controller_path == 'admin/job_types'}" %>
      <%= link_to "Campaigns", admin_campaigns_path, class: "nav-link #{'active' if controller_name == 'campaigns'}" %>

      <h6 class="text-uppercase text-muted small mt-3 mb-1 px-3">LLM</h6>
      <%= link_to "Chats", admin_chats_path, class: "nav-link #{'active' if controller_path == 'admin/chats'}" %>
      <%= link_to "Messages", admin_messages_path, class: "nav-link #{'active' if controller_path == 'admin/messages'}" %>
      <%= link_to "Tool Calls", admin_tool_calls_path, class: "nav-link #{'active' if controller_path == 'admin/tool_calls'}" %>
      <%= link_to "Models", admin_models_path, class: "nav-link #{'active' if controller_path == 'admin/models'}" %>
      <%= link_to "PDF Revisions", admin_pdf_processing_revisions_path, class: "nav-link #{'active' if controller_path == 'admin/pdf_processing_revisions'}" %>
    <% end %>
  </nav>
</aside>
