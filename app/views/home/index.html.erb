<% content_for :title, "Home" %>

<div class="mb-4">
  <h1 class="h3 mb-1">Welcome<%= ", #{current_user.full_name || current_user.email}" %></h1>
  <p class="text-muted mb-0">Pick where you'd like to go.</p>
</div>

<% needs_attention_n = needs_attention_count %>

<div class="row g-4">
  <div class="col-md-6">
    <%= link_to job_proposals_path, class: "card h-100 text-decoration-none text-reset home-card" do %>
      <div class="card-body p-4 text-center">
        <div class="home-card-icon mx-auto mb-3">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
        </div>
        <h2 class="h4 fw-bold mb-2">Proposals</h2>
        <p class="text-muted mb-0">Browse every job proposal across your team.</p>
      </div>
    <% end %>
  </div>

  <div class="col-md-6">
    <%= link_to job_proposals_path(filter: "needs_attention"), class: "card h-100 text-decoration-none text-reset home-card position-relative" do %>
      <% if needs_attention_n > 0 %>
        <span class="badge text-bg-danger rounded-pill position-absolute top-0 end-0 m-3"><%= needs_attention_n %></span>
      <% end %>
      <div class="card-body p-4 text-center">
        <div class="home-card-icon mx-auto mb-3">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/>
            <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>
          </svg>
        </div>
        <h2 class="h4 fw-bold mb-2">Needs Attention</h2>
        <p class="text-muted mb-0">Proposals waiting on you to draft, approve, or follow up.</p>
      </div>
    <% end %>
  </div>

  <div class="col-md-6">
    <%= link_to users_path, class: "card h-100 text-decoration-none text-reset home-card" do %>
      <div class="card-body p-4 text-center">
        <div class="home-card-icon mx-auto mb-3">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <h2 class="h4 fw-bold mb-2">Team</h2>
        <p class="text-muted mb-0">See your teammates and invite new ones.</p>
      </div>
    <% end %>
  </div>

  <div class="col-md-6">
    <%= link_to analytics_path, class: "card h-100 text-decoration-none text-reset home-card" do %>
      <div class="card-body p-4 text-center">
        <div class="home-card-icon mx-auto mb-3">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 3v18h18"/>
            <path d="M18 17V9"/>
            <path d="M13 17V5"/>
            <path d="M8 17v-3"/>
          </svg>
        </div>
        <h2 class="h4 fw-bold mb-2">Analytics</h2>
        <p class="text-muted mb-0">Track proposal volume, wins, and revenue trends.</p>
      </div>
    <% end %>
  </div>
</div>
